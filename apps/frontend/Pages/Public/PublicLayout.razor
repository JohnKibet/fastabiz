@inherits LayoutComponentBase
@namespace frontend.Pages.Public
@using frontend.Pages.Shared
@using MudBlazor

@*
    PublicLayout wraps all unauthenticated pages: home, login, register, storefront.
    AppTheme provides MudThemeProvider — no per-page theme needed.
    MudSnackbarProvider and MudDialogProvider are here so toasts/dialogs
    work on public pages (e.g. login errors).
*@

<AppTheme />
<MudSnackbarProvider />
<MudDialogProvider />

<div class="flex flex-col min-h-screen">
    @Body
</div>
