@page "/merchant/operations/assignments"
@layout MerchantLayout
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs

<MudText Typo="Typo.h5" Style="font-weight:800;" Class="mb-6">Order Assignment</MudText>

<MudPaper Elevation="2" Class="pa-5 rounded-xl mb-6">
    <div class="d-flex align-center justify-space-between flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Smart Auto-Assignment</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Automatically assign drivers based on proximity and availability.</MudText>
        </div>
        <MudSwitch @bind-Value="_autoAssign" Color="Color.Primary" Label="@(_autoAssign ? "Enabled" : "Disabled")" />
    </div>
    @if (_autoAssign)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle2" Style="font-weight:700;" Class="mb-3">Rules</MudText>
        <div class="d-flex flex-column gap-2">
            <MudCheckBox @bind-Value="_highTraffic"     Color="Color.Primary" Label="Trigger during high order traffic" />
            <MudCheckBox @bind-Value="_instantCancel"   Color="Color.Primary" Label="Instant notification on cancellation" />
            <MudCheckBox @bind-Value="_reassignOnDelay" Color="Color.Primary" Label="Auto re-assign on delivery delay" />
        </div>
    }
</MudPaper>

<MudPaper Elevation="2" Class="pa-5 rounded-xl">
    <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-4">Incoming Orders</MudText>
    @foreach (var order in _orders)
    {
        <MudPaper Elevation="0" Class="pa-4 rounded-xl mb-3" Style="border:1px solid #e5e7eb;">
            <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                <div>
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700;">@order.Name</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">@order.Description</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Qty: @order.Quantity · SKU: @order.SKU</MudText>
                </div>
                <div class="d-flex align-center gap-3">
                    @if (order.AssignedDriverId.HasValue)
                    {
                        var driver = _drivers.FirstOrDefault(d => d.DriverId == order.AssignedDriverId);
                        <MudChip T="string" Color="Color.Success" Variant="MudVariant.Filled" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Label="true">@(driver?.Name ?? "Assigned")</MudChip>
                    }
                    else if (_autoAssign)
                    {
                        <MudChip T="string" Color="Color.Info" Variant="MudVariant.Outlined" Size="Size.Small" Icon="@Icons.Material.Filled.AutoMode" Label="true">Auto-assigning…</MudChip>
                    }
                    else
                    {
                        <SelectField TValue="Guid?" TItem="MockDriver" Label="Assign driver"
                                     Items="@_drivers.Where(d => d.IsOnline).ToList()"
                                     Value="@order.AssignedDriverId"
                                     ValueChanged="@(id => AssignDriver(order, id))"
                                     ItemValue="@(d => (Guid?)d.DriverId)"
                                     ItemText="@(d => $"{d.Name} (⭐ {d.Rating})")" />
                    }
                </div>
            </div>
        </MudPaper>
    }
</MudPaper>

@code {
    private bool _autoAssign = true;
    private bool _highTraffic = true;
    private bool _instantCancel = true;
    private bool _reassignOnDelay = true;

    private class MockOrder
    {
        public Guid OrderId { get; set; } = Guid.NewGuid();
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public string SKU { get; set; } = string.Empty;
        public Guid? AssignedDriverId { get; set; }
    }

    private class MockDriver
    {
        public Guid DriverId { get; set; } = Guid.NewGuid();
        public string Name { get; set; } = string.Empty;
        public double Rating { get; set; }
        public bool IsOnline { get; set; }
    }

    private List<MockOrder> _orders = new()
    {
        new() { Name = "Fresh Apples",    Description = "Crisp organic apples.",      Quantity = 2, SKU = "APP-SM-001" },
        new() { Name = "Organic Bananas", Description = "Naturally ripened bananas.", Quantity = 5, SKU = "BAN-YL-002" },
        new() { Name = "Fresh Milk",      Description = "Locally sourced farm milk.", Quantity = 1, SKU = "MLK-FR-003" },
    };

    private List<MockDriver> _drivers = new()
    {
        new() { Name = "James Mwangi",  Rating = 4.8, IsOnline = true  },
        new() { Name = "Alice Wanjiru", Rating = 4.9, IsOnline = true  },
        new() { Name = "Peter Otieno",  Rating = 4.2, IsOnline = false },
    };

    private void AssignDriver(MockOrder order, Guid? id)
    {
        order.AssignedDriverId = id;
        // TODO: call AssignmentService.AssignDriver(order.OrderId, id)
    }
}
