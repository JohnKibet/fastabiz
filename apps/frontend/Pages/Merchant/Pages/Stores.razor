@page "/merchant/stores"
@layout MerchantLayout
@using frontend.Models
@using frontend.Models.Storefront
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject StoreService StoreService
@inject ToastService ToastService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "merchant")]

<!-- ── Page header ── -->
<div class="d-flex align-center justify-space-between mb-6 flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:800;">Store Management</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@_stores?.Count store@(_stores?.Count == 1 ? "" : "s")</MudText>
    </div>
    <MudButton Href="/merchant/stores/create"
               Variant="MudVariant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Style="border-radius:8px; font-weight:700;">
        Create Store
    </MudButton>
</div>

<!-- ── Search ── -->
<MudTextField @bind-Value="_search"
              Placeholder="Search by name or location..."
              Variant="MudVariant.Outlined"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Margin="Margin.Dense"
              Class="mb-6"
              Style="max-width:400px;"
              Immediate="true" />

<!-- ── Grid ── -->
<AppGrid TItem="StoreDto"
         Items="@FilteredStores"
         Loading="@_loading"
         EmptyText="No stores found. Create your first store.">

    <ColDefs>
        <MudTh>Store</MudTh>
        <MudTh>Location</MudTh>
        <MudTh>Rating</MudTh>
        <MudTh>Products</MudTh>
        <MudTh>Created</MudTh>
        <MudTh></MudTh>
    </ColDefs>

    <RowTemplate Context="store">
        <MudTd>
            <div class="d-flex align-center gap-3">
                <MudAvatar Rounded="true" Style="background:#f3f4f6; width:36px; height:36px;">
                    @if (!string.IsNullOrEmpty(store.LogoUrl))
                    {
                        <MudImage Src="@store.LogoUrl" Alt="@store.Name" Style="width:36px; height:36px; object-fit:cover;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Store" Style="color:#9ca3af;" />
                    }
                </MudAvatar>
                <MudText Typo="Typo.body2" Style="font-weight:600;">@store.Name</MudText>
            </div>
        </MudTd>
        <MudTd>
            <div class="d-flex align-center gap-1">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Style="color:#9ca3af;" />
                <MudText Typo="Typo.body2">@store.Location</MudText>
            </div>
        </MudTd>
        <MudTd>
            @if (store.Rating.HasValue)
            {
                <div class="d-flex align-center gap-1">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                    <MudText Typo="Typo.body2">@store.Rating.Value.ToString("F1")</MudText>
                </div>
            }
            else
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
            }
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="MudVariant.Outlined" Color="Color.Default" Label="true">
                @(store.TotalProducts ?? 0)
            </MudChip>
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @(DateTime.TryParse(store.CreatedAt, out var dt) ? dt.ToString("MMM d, yyyy") : "—")
            </MudText>
        </MudTd>
        <MudTd>
            <span @onclick:stopPropagation="true" class="d-inline-flex gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => OpenModal(store, editMode: false))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => OpenModal(store, editMode: true))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => ConfirmDelete(store))" />
            </span>
        </MudTd>
    </RowTemplate>

</AppGrid>

<!-- ── Edit / View dialog ── -->
<MudDialog @bind-IsVisible="_modalOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_editMode ? "Edit Store" : _selectedStore?.Name)
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_editMode)
        {
            <MudTextField @bind-Value="_editRequest.Name"
                          Label="Store Name"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Class="mb-4" />
            <MudTextField @bind-Value="_editRequest.Location"
                          Label="Location"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Class="mb-4" />
            <MudTextField @bind-Value="_editRequest.LogoUrl"
                          Label="Logo URL"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Class="mb-4" />
        }
        else
        {
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Store">
                    <MudText Typo="Typo.body2"><strong>Name:</strong> @_selectedStore?.Name</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.LocationOn">
                    <MudText Typo="Typo.body2"><strong>Location:</strong> @_selectedStore?.Location</MudText>
                </MudListItem>
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        @if (!_editMode)
        {
            <MudButton Variant="MudVariant.Outlined" OnClick="@(() => _editMode = true)"
                       StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
        }
        else
        {
            <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                       OnClick="SaveChanges" Disabled="@_saving">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save
            </MudButton>
        }
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _modalOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<!-- ── Delete confirm dialog ── -->
<MudDialog @bind-IsVisible="_deleteOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">Delete Store</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1">
            Are you sure you want to delete <strong>@_deleteTargetName</strong>? This cannot be undone.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="MudVariant.Filled" Color="Color.Error"
                   OnClick="DeleteStore" Disabled="@_saving">Delete</MudButton>
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _deleteOpen = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<StoreDto>? _stores;
    private string   _search  = string.Empty;
    private bool     _loading = true;

    // Modal state
    private bool              _modalOpen  = false;
    private bool              _editMode   = false;
    private bool              _saving     = false;
    private StoreDto?         _selectedStore;
    private UpdateStoreRequest _editRequest = new();

    // Delete state
    private bool   _deleteOpen       = false;
    private Guid   _deleteTargetId;
    private string _deleteTargetName = string.Empty;

    private IEnumerable<StoreDto> FilteredStores =>
        _stores?.Where(s =>
            string.IsNullOrWhiteSpace(_search) ||
            s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            s.Location.Contains(_search, StringComparison.OrdinalIgnoreCase)
        ) ?? Enumerable.Empty<StoreDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadStores();
        _loading = false;
    }

    private async Task LoadStores()
    {
        var result = await StoreService.GetAllStores();
        _stores = result.Success && result.Data != null ? result.Data : new();
    }

    private void OpenModal(StoreDto store, bool editMode)
    {
        _selectedStore = store;
        _editRequest   = new UpdateStoreRequest
        {
            Name     = store.Name,
            Location = store.Location,
            LogoUrl  = store.LogoUrl
        };
        _editMode  = editMode;
        _modalOpen = true;
    }

    private async Task SaveChanges()
    {
        if (_selectedStore is null) return;
        _saving = true;

        var result = await StoreService.UpdateStore(_selectedStore.Id, _editRequest);
        _saving = false;

        if (result.Success)
        {
            await LoadStores();
            ToastService.ShowToast("Store updated successfully", string.Empty, ToastService.ToastLevel.Success);
            _modalOpen = false;
        }
        else
        {
            ToastService.ShowToast(result.Error?.Message ?? "Failed to update store.", string.Empty, ToastService.ToastLevel.Error);
        }
    }

    private void ConfirmDelete(StoreDto store)
    {
        _deleteTargetId   = store.Id;
        _deleteTargetName = store.Name;
        _deleteOpen       = true;
    }

    private async Task DeleteStore()
    {
        _saving = true;
        var result = await StoreService.DeleteStore(_deleteTargetId);
        _saving = false;
        _deleteOpen = false;

        if (result.Success)
        {
            await LoadStores();
            ToastService.ShowToast("Store deleted.", string.Empty, ToastService.ToastLevel.Success);
        }
        else
        {
            ToastService.ShowToast(result.Error?.Message ?? "Failed to delete store.", string.Empty, ToastService.ToastLevel.Error);
        }
    }
}
