@page "/merchant/map"
@namespace frontend.Pages.Merchant.LiveMap
@layout MerchantLayout
@using MudBlazor

<MudText Typo="Typo.h5" Style="font-weight:800;" Class="mb-4">Live Driver Map</MudText>

<MudPaper Elevation="2" Class="pa-0 rounded-xl" Style="overflow:hidden; height:calc(100vh - 180px);">
    <RealTimeMap @ref="_map"
                 Parameters="_params"
                 height="100%"
                 width="100%" />
</MudPaper>

@code {
    private RealTimeMap? _map;

    private static readonly string _openCycleKey = "";  // set via appsettings or env

    private readonly RealTimeMap.LoadParameters _params = new()
    {
        basemap = new RealTimeMap.Basemap
        {
            basemapLayers = new List<RealTimeMap.BasemapLayer>
            {
                new() { url = "http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",       attribution = "©OpenStreetMap",  title = "OpenStreetMap",  detectRetina = true },
                new() { url = "https://tile.opentopomap.org/{z}/{x}/{y}.png",            attribution = "OpenTopo",        title = "Open Topo",      detectRetina = true },
                new() { url = $"https://tile.thunderforest.com/cycle/{{z}}/{{x}}/{{y}}.png?apikey={_openCycleKey}",
                        attribution = "©OpenCycleMap", title = "Cycle Map" },
            }
        },
        location  = new RealTimeMap.Location { latitude = -1.29207, longitude = 36.82195 },
        zoomLevel = 14
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _map is null) return;

        // TODO: replace with real driver positions from DeliveryService
        var points = new List<RealTimeMap.StreamPoint>
        {
            new() { guid = Guid.NewGuid(), timestamp = DateTime.UtcNow, latitude = -1.2921, longitude = 36.8219, type = "driver",      value = "Driver A" },
            new() { guid = Guid.NewGuid(), timestamp = DateTime.UtcNow, latitude = -1.3000, longitude = 36.8300, type = "destination", value = "Drop-off" },
        };

        await _map.Geometric.Points.upload(points, true);
    }
}
