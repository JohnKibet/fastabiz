@page "/merchant/users"
@layout MerchantLayout
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject UserService UserService
@inject ToastService ToastService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "merchant")]

<!-- ── Page header ── -->
<div class="d-flex align-center justify-space-between mb-6 flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:800;">User Management</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@_users?.Count total user@(_users?.Count == 1 ? "" : "s")</MudText>
    </div>
    <div class="d-flex gap-2">
        <MudButton OnClick="@(() => Navigation.NavigateTo("/merchant/createuser"))"
                   Variant="MudVariant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   Style="border-radius:8px; font-weight:700;">
            Add User
        </MudButton>
        <MudButton OnClick="ExportUsers"
                   Variant="MudVariant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   Style="border-radius:8px; font-weight:600;">
            Export CSV
        </MudButton>
    </div>
</div>

<!-- ── Filters ── -->
<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="12" sm="6" md="4">
        <MudTextField @bind-Value="_search"
                      Placeholder="Search by name or email..."
                      Variant="MudVariant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Immediate="true" />
    </MudItem>
    <MudItem xs="12" sm="3" md="2">
        <SelectField TValue="string"
                     TItem="string"
                     Label="Role"
                     Options="@_roleOptions"
                     @bind-Value="_filterRole" />
    </MudItem>
    <MudItem xs="12" sm="3" md="2">
        <SelectField TValue="string"
                     TItem="string"
                     Label="Status"
                     Options="@_statusOptions"
                     @bind-Value="_filterStatus" />
    </MudItem>
</MudGrid>

<!-- ── Grid ── -->
<AppGrid TItem="User"
         Items="@FilteredUsers"
         Loading="@_loading"
         EmptyText="No users found.">

    <ColDefs>
        <MudTh>User</MudTh>
        <MudTh>Role</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Last Login</MudTh>
        <MudTh></MudTh>
    </ColDefs>

    <RowTemplate Context="user">
        <MudTd>
            <div class="d-flex align-center gap-3">
                <MudAvatar Style="background:#f97316; color:white; font-weight:700; width:34px; height:34px; font-size:0.85rem;">
                    @(user.FullName?.Length > 0 ? user.FullName[0].ToString().ToUpper() : "U")
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.body2" Style="font-weight:600;">@user.FullName</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@user.Email</MudText>
                </div>
            </div>
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="MudVariant.Outlined" Color="Color.Default" Label="true">
                @user.Role
            </MudChip>
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="MudVariant.Filled" Label="true"
                     Color="@GetStatusColor(user.Status)">
                @user.Status
            </MudChip>
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @(user.LastLogin.HasValue ? user.LastLogin.Value.ToString("MMM d, yyyy") : "Never")
            </MudText>
        </MudTd>
        <MudTd>
            <span @onclick:stopPropagation="true" class="d-inline-flex gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => OpenModal(user, editMode: false))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => OpenModal(user, editMode: true))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => ConfirmDelete(user))" />
            </span>
        </MudTd>
    </RowTemplate>

</AppGrid>

<!-- ── View / Edit dialog ── -->
<MudDialog @bind-IsVisible="_modalOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_editMode ? "Edit User" : _selectedUser?.FullName)
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_editMode)
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                Update status for <strong>@_selectedUser?.FullName</strong>
            </MudText>
            <SelectField TValue="UserStatus?"
                         TItem="UserStatus?"
                         Label="Status"
                         Options="@_statusEnumOptions"
                         @bind-Value="_editStatus" />
        }
        else
        {
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Person">
                    <MudText Typo="Typo.body2"><strong>Name:</strong> @_selectedUser?.FullName</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Email">
                    <MudText Typo="Typo.body2"><strong>Email:</strong> @_selectedUser?.Email</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Badge">
                    <MudText Typo="Typo.body2"><strong>Role:</strong> @_selectedUser?.Role</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Circle">
                    <MudText Typo="Typo.body2"><strong>Status:</strong> @_selectedUser?.Status</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.AccessTime">
                    <MudText Typo="Typo.body2">
                        <strong>Last Login:</strong>
                        @(_selectedUser?.LastLogin.HasValue == true
                            ? _selectedUser.LastLogin.Value.ToString("MMM d, yyyy HH:mm")
                            : "Never")
                    </MudText>
                </MudListItem>
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        @if (!_editMode)
        {
            <MudButton Variant="MudVariant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="@(() => _editMode = true)">Edit</MudButton>
        }
        else
        {
            <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                       OnClick="SaveChanges" Disabled="@_saving">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save
            </MudButton>
        }
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _modalOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<!-- ── Delete confirm dialog ── -->
<MudDialog @bind-IsVisible="_deleteOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">Delete User</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1">
            Are you sure you want to delete <strong>@_deleteTargetName</strong>? This cannot be undone.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="MudVariant.Filled" Color="Color.Error"
                   OnClick="DeleteUser" Disabled="@_saving">Delete</MudButton>
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _deleteOpen = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<User>? _users;
    private string  _search       = string.Empty;
    private string  _filterRole   = string.Empty;
    private string  _filterStatus = string.Empty;
    private bool    _loading      = true;

    // Modal state
    private bool        _modalOpen = false;
    private bool        _editMode  = false;
    private bool        _saving    = false;
    private User?       _selectedUser;
    private UserStatus? _editStatus;

    // Delete state
    private bool   _deleteOpen       = false;
    private Guid   _deleteTargetId;
    private string _deleteTargetName = string.Empty;

    // Filter options
    private static readonly List<string> _roleOptions   = new() { "", "merchant", "customer", "driver" };
    private static readonly List<string> _statusOptions =
        new[] { "" }.Concat(Enum.GetNames<UserStatus>()).ToList();
    private static readonly List<UserStatus?> _statusEnumOptions =
        Enum.GetValues<UserStatus>().Cast<UserStatus?>().ToList();

    private IEnumerable<User> FilteredUsers =>
        _users?.Where(u =>
            (string.IsNullOrEmpty(_search)       || u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase) || u.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_filterRole)   || u.Role == _filterRole) &&
            (string.IsNullOrEmpty(_filterStatus) || u.Status?.ToString() == _filterStatus)
        ) ?? Enumerable.Empty<User>();

    protected override async Task OnInitializedAsync()
    {
        var result = await UserService.GetAllCachedUsers();
        _users   = result.Success && result.Data != null ? result.Data : new();
        _loading = false;
    }

    private void OpenModal(User user, bool editMode)
    {
        _selectedUser = user;
        _editStatus   = user.Status;
        _editMode     = editMode;
        _modalOpen    = true;
    }

    private async Task SaveChanges()
    {
        if (_selectedUser is null) return;

        if (_editStatus == _selectedUser.Status || _editStatus is null)
        {
            ToastService.ShowToast("No changes were made.", string.Empty, ToastService.ToastLevel.Warning);
            _modalOpen = false;
            return;
        }

        _saving = true;
        var result = await UserService.UpdateStatus(_selectedUser.ID, _editStatus.Value);
        _saving = false;

        if (result.Success)
        {
            var refresh = await UserService.GetAllUsers();
            if (refresh.Success && refresh.Data != null) _users = refresh.Data;
            ToastService.ShowToast("User status updated.", string.Empty, ToastService.ToastLevel.Success);
        }
        else
        {
            ToastService.ShowToast(result.Error?.Message ?? "Failed to update status.", string.Empty, ToastService.ToastLevel.Error);
        }

        _modalOpen = false;
    }

    private void ConfirmDelete(User user)
    {
        _deleteTargetId   = user.ID;
        _deleteTargetName = user.FullName;
        _deleteOpen       = true;
    }

    private async Task DeleteUser()
    {
        _saving = true;
        var success = await UserService.DeleteUser(_deleteTargetId);
        _saving     = false;
        _deleteOpen = false;

        if (success)
        {
            var result = await UserService.GetAllUsers();
            if (result.Success && result.Data != null) _users = result.Data;
            ToastService.ShowToast("User deleted.", string.Empty, ToastService.ToastLevel.Success);
        }
        else
        {
            ToastService.ShowToast("Failed to delete user.", string.Empty, ToastService.ToastLevel.Error);
        }
    }

    private static Color GetStatusColor(UserStatus? status) => status switch
    {
        UserStatus.Active    => Color.Success,
        UserStatus.Suspended => Color.Error,
        UserStatus.Pending   => Color.Warning,
        UserStatus.Inactive  => Color.Default,
        _                    => Color.Default
    };

    private void ExportUsers() { /* TODO */ }
}
