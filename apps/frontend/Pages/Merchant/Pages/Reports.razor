@page "/merchant/reports"
@layout MerchantLayout
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs

@attribute [Authorize(Roles = "merchant")]

<div class="d-flex align-center justify-space-between mb-6">
    <MudText Typo="Typo.h5" Style="font-weight:800;">Delivery and Revenue Reports</MudText>
    <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PictureAsPdf"
               Style="border-radius:8px; font-weight:700;">
        Export PDF
    </MudButton>
</div>

<!-- Time filter -->
<MudPaper Elevation="0" Class="pa-0 mb-6 d-flex align-center gap-3">
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Filter by:</MudText>
    <SelectField TValue="string" TItem="string"
                 Label="Period"
                 Options="@_periods"
                 @bind-Value="_period"
                 Class="mb-0" />
</MudPaper>

<!-- Delivery performance -->
<MudPaper Elevation="2" Class="pa-6 rounded-xl mb-6">
    <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Delivery Performance</MudText>
    <MudGrid Spacing="4" Class="mb-6">
        <MudItem xs="12" sm="4">
            <MetricCard Title="Completed"  Value="110" Icon="box"   Highlight="success" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MetricCard Title="In Transit" Value="7"   Icon="truck" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MetricCard Title="Delayed"    Value="3"   Icon="clock" Highlight="danger" />
        </MudItem>
    </MudGrid>
    <MudPaper Elevation="0" Class="d-flex align-center justify-center rounded-xl"
              Style="height:220px; background:#f9fafb; border:2px dashed #e5e7eb;">
        <div class="d-flex flex-column align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="font-size:3rem; color:#d1d5db;" />
            <MudText Typo="Typo.body2" Style="color:#9ca3af;">Delivery trend chart — coming soon</MudText>
        </div>
    </MudPaper>
</MudPaper>

<!-- Revenue -->
<MudPaper Elevation="2" Class="pa-6 rounded-xl mb-6">
    <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Revenue Analysis</MudText>
    <MudGrid Spacing="4" Class="mb-4">
        <MudItem xs="12" sm="6">
            <MetricCard Title="Total Revenue (This Month)" Value="$4,200" Icon="dollar-sign" Highlight="success" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MetricCard Title="Avg Order Value" Value="$120" Icon="dollar-sign" />
        </MudItem>
    </MudGrid>
    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="0" Class="d-flex align-center justify-center rounded-xl"
                      Style="height:180px; background:#f9fafb; border:2px dashed #e5e7eb;">
                <MudText Typo="Typo.body2" Style="color:#9ca3af;">Revenue by week</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="0" Class="d-flex align-center justify-center rounded-xl"
                      Style="height:180px; background:#f9fafb; border:2px dashed #e5e7eb;">
                <MudText Typo="Typo.body2" Style="color:#9ca3af;">Revenue by category</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Recent table -->
<MudPaper Elevation="2" Class="pa-6 rounded-xl">
    <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Recent Deliveries and Payments</MudText>
    <AppGrid TItem="ReportRow" Items="@_rows" Dense="true" EmptyText="No data.">
        <ColDefs>
            <MudTh>Order ID</MudTh>
            <MudTh>Customer</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Amount</MudTh>
            <MudTh>Date</MudTh>
        </ColDefs>
        <RowTemplate Context="row">
            <MudTd><MudText Typo="Typo.body2" Style="font-family:monospace;">@row.OrderId</MudText></MudTd>
            <MudTd>@row.Customer</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="MudVariant.Filled" Label="true"
                         Color="@(row.Status == "Completed" ? Color.Success : Color.Info)">
                    @row.Status
                </MudChip>
            </MudTd>
            <MudTd><MudText Typo="Typo.body2" Style="font-weight:600;">@row.Amount</MudText></MudTd>
            <MudTd><MudText Typo="Typo.caption" Class="mud-text-secondary">@row.Date</MudText></MudTd>
        </RowTemplate>
    </AppGrid>
</MudPaper>

@code {
    private string _period = "This Month";
    private static readonly List<string> _periods = new() { "This Week", "This Month", "Last 3 Months", "Year to Date" };

    private record ReportRow(string OrderId, string Customer, string Status, string Amount, string Date);

    // TODO: replace with real API data from OrderService/ReportService
    private readonly List<ReportRow> _rows = new()
    {
        new("ORD102", "Jane Smith", "Completed",  "$150", "Sep 10, 2025"),
        new("ORD103", "John Doe",   "In Transit", "$200", "Sep 11, 2025"),
    };
}
