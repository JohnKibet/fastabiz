@using MudBlazor
@inject MapService MapService
@inject GeoService GeoService
@inject IJSRuntime JS
@implements IDisposable

@*
    CustomerMap — wraps RealTimeMap and fires address callbacks on pin drop.

    USAGE:
        <CustomerMap CurrentMode="@_mode"
                     OnDeliverySelected="@(addr => _deliveryAddress = addr)"
                     OnPickupSelected="@(addr => _pickupAddress = addr)" />
*@

<div @ref="_container" style="height:500px; width:100%; border-radius:12px; overflow:hidden;">
    <RealTimeMap @ref="_map"
                 Parameters="_params"
                 OnClickMap="HandleMapClick"
                 height="500px"
                 width="100%" />
</div>

@code {
    [Parameter] public MapClickMode                 CurrentMode         { get; set; } = MapClickMode.Delivery;
    [Parameter] public EventCallback<string>        OnDeliverySelected  { get; set; }
    [Parameter] public EventCallback<string>        OnPickupSelected    { get; set; }

    public enum MapClickMode { Delivery, Pickup }

    private ElementReference         _container;
    private RealTimeMap?             _map;
    private RealTimeMap.LoadParameters? _params;
    private DotNetObjectReference<CustomerMap>? _dotNetRef;

    public double? SelectedLatitude  { get; private set; }
    public double? SelectedLongitude { get; private set; }

    protected override void OnInitialized()
    {
        _params = new RealTimeMap.LoadParameters
        {
            basemap = new RealTimeMap.Basemap
            {
                basemapLayers = MapService.GetDefaultBasemapLayers()
            },
            location = new RealTimeMap.Location
            {
                latitude  = -1.29207,
                longitude = 36.82195
            },
            zoomLevel = 14
        };
    }

    private async Task HandleMapClick(RealTimeMap.ClicksMapArgs args)
    {
        var lat = args.location.latitude;
        var lng = args.location.longitude;

        SelectedLatitude  = lat;
        SelectedLongitude = lng;

        var address = await GeoService.GetAddressAsync(lat, lng) ?? "Unknown location";

        await JS.InvokeVoidAsync("addAwesomeMarker", _container, lat, lng, new
        {
            icon        = "map-pin",
            markerColor = CurrentMode == MapClickMode.Delivery ? "blue" : "green",
            prefix      = "fa"
        });

        if (CurrentMode == MapClickMode.Delivery)
            await OnDeliverySelected.InvokeAsync(address);
        else
            await OnPickupSelected.InvokeAsync(address);
    }

    public void Dispose() => _dotNetRef?.Dispose();
}
