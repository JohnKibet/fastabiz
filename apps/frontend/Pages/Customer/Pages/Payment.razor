@page "/customer/payment"
@layout CustomerLayout
@using frontend.Models
@using Microsoft.AspNetCore.WebUtilities
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@inject CartService CartService
@inject OrderService OrderService
@inject PaymentService PaymentService
@inject ToastService ToastService
@inject NavigationManager Navigation

<!-- ── Page header ── -->
<MudText Typo="Typo.h5" Style="font-weight:800;" Class="mb-6">Payment</MudText>

@if (!CartService.Items.Any())
{
    <MudPaper Elevation="2" Class="pa-10 rounded-xl d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart"
                 Style="font-size:4rem; color:#d1d5db;" Class="mb-4" />
        <MudText Typo="Typo.h6" Class="mb-3" Style="color:#374151;">Your cart is empty</MudText>
        <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                   OnClick="@(() => Navigation.NavigateTo("/storefront"))"
                   Style="border-radius:8px; font-weight:700;">
            Shop Now
        </MudButton>
    </MudPaper>
}
else
{
    <MudGrid Spacing="5">

        <!-- Order summary -->
        <MudItem xs="12" lg="6">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Order Summary</MudText>

                @foreach (var item in CartService.Items)
                {
                    <div class="d-flex align-center justify-space-between py-3"
                         style="border-bottom:1px solid #f3f4f6;">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Rounded="true" Style="width:40px; height:40px; background:#f3f4f6;">
                                @if (!string.IsNullOrEmpty(item.Thumbnail))
                                {
                                    <MudImage Src="@item.Thumbnail" Alt="@item.Name"
                                              Style="width:40px; height:40px; object-fit:cover;" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="color:#9ca3af;" />
                                }
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@item.Name</MudText>
                                @if (!string.IsNullOrEmpty(item.VariantName))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@item.VariantName</MudText>
                                }
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">× @item.Quantity</MudText>
                            </div>
                        </div>
                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                            @((item.Price * item.Quantity).ToString("C"))
                        </MudText>
                    </div>
                }

                <div class="d-flex align-center justify-space-between mt-4 pt-4"
                     style="border-top:2px solid #e5e7eb;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Total</MudText>
                    <MudText Typo="Typo.h6" Style="font-weight:800; color:#16a34a;">
                        @CartService.Total.ToString("C")
                    </MudText>
                </div>

                <!-- Delivery summary -->
                @if (!string.IsNullOrEmpty(_deliveryAddress))
                {
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Delivery to</MudText>
                    <MudText Typo="Typo.body2">@_deliveryAddress</MudText>
                }
            </MudPaper>
        </MudItem>

        <!-- Payment methods -->
        <MudItem xs="12" lg="6">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Payment Method</MudText>

                <!-- Cash on delivery -->
                <MudPaper @onclick='() => _method = "cod"'
                          Elevation="@(_method == "cod" ? 3 : 1)"
                          Class="pa-4 rounded-xl mb-3 cursor-pointer"
                          Style="@($"border:2px solid {(_method == "cod" ? "var(--mud-palette-primary)" : "transparent")}; transition:all 0.15s;")">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Default" />
                        <div>
                            <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Cash on Delivery</MudText>
                            @if (_method == "cod")
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Pay the delivery person when you receive your order.
                                </MudText>
                            }
                        </div>
                        @if (_method == "cod")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Color="Color.Primary" Class="ml-auto" />
                        }
                    </div>
                </MudPaper>

                <!-- M-Pesa Express -->
                <MudPaper @onclick='() => _method = "mpesa-express"'
                          Elevation="@(_method == "mpesa-express" ? 3 : 1)"
                          Class="pa-4 rounded-xl mb-4 cursor-pointer"
                          Style="@($"border:2px solid {(_method == "mpesa-express" ? "var(--mud-palette-primary)" : "transparent")}; transition:all 0.15s;")">
                    <div class="d-flex align-center gap-3 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Color="Color.Default" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">M-Pesa Express</MudText>
                        @if (_method == "mpesa-express")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Color="Color.Primary" Class="ml-auto" />
                        }
                    </div>

                    @if (_method == "mpesa-express")
                    {
                        <MudTextField @bind-Value="_mpesaPhone"
                                      Label="Phone Number"
                                      Placeholder="+2547XXXXXXXX"
                                      Variant="MudVariant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Class="mb-3"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Phone" />
                        <MudTextField @bind-Value="_mpesaAmount"
                                      Label="Amount"
                                      Variant="MudVariant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Adornment="Adornment.Start"
                                      AdornmentText="KES" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                            You will receive an M-Pesa prompt on your phone.
                        </MudText>
                    }
                </MudPaper>

                <MudButton Variant="MudVariant.Filled" Color="Color.Secondary"
                           FullWidth="true" Size="Size.Large"
                           OnClick="ConfirmPayment"
                           Disabled="@_paying"
                           Style="border-radius:10px; font-weight:700;">
                    @if (_paying)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Processing…</span>
                    }
                    else
                    {
                        <span>Pay @CartService.Total.ToString("C")</span>
                    }
                </MudButton>

            </MudPaper>
        </MudItem>

    </MudGrid>
}

@code {
    [CascadingParameter] public Guid? UserId { get; set; }

    private string _method        = "cod";
    private string _mpesaPhone    = string.Empty;
    private string _mpesaAmount   = string.Empty;
    private bool   _paying        = false;

    private string _deliveryAddress = string.Empty;
    private string _pickupAddress   = string.Empty;
    private double _deliveryLat, _deliveryLng;
    private double _pickupLat,   _pickupLng;

    protected override void OnInitialized()
    {
        if (!UserId.HasValue)
        {
            Navigation.NavigateTo("/auth/login");
            return;
        }

        var query = QueryHelpers.ParseQuery(
            Navigation.ToAbsoluteUri(Navigation.Uri).Query);

        _deliveryAddress = query["delivery"].ToString();
        _pickupAddress   = query["pickup"].ToString();
        double.TryParse(query["delLat"],  out _deliveryLat);
        double.TryParse(query["delLng"],  out _deliveryLng);
        double.TryParse(query["pickLat"], out _pickupLat);
        double.TryParse(query["pickLng"], out _pickupLng);

        // Pre-fill MPesa amount from cart total
        _mpesaAmount = CartService.Total.ToString("F0");
    }

    private async Task ConfirmPayment()
    {
        if (!CartService.Items.Any())
        {
            ToastService.ShowToast("Your cart is empty.", string.Empty, ToastService.ToastLevel.Warning);
            return;
        }

        _paying = true;

        try
        {
            // ── M-Pesa STK push ───────────────────────────────────────
            if (_method == "mpesa-express")
            {
                if (string.IsNullOrWhiteSpace(_mpesaPhone) || string.IsNullOrWhiteSpace(_mpesaAmount))
                {
                    ToastService.ShowToast("Phone number and amount are required.", string.Empty, ToastService.ToastLevel.Warning);
                    return;
                }

                var mpesaResult = await PaymentService.StartMpesaExpressAsync(_mpesaPhone, _mpesaAmount);

                if (!mpesaResult.Success)
                {
                    ToastService.ShowToast(
                        mpesaResult.Error?.Message ?? "Failed to initiate M-Pesa payment.",
                        string.Empty, ToastService.ToastLevel.Error);
                    return;
                }

                ToastService.ShowToast(
                    mpesaResult.Data?.CustomerMessage ?? "M-Pesa prompt sent — check your phone.",
                    string.Empty, ToastService.ToastLevel.Info);
            }

            // ── Create order ──────────────────────────────────────────
            var request = new CreateOrderRequest
            {
                StoreId       = CartService.Items.First().StoreId,
                CustomerId    = UserId!.Value,
                PaymentMethod = _method,
                Delivery = new LocationDto
                {
                    Address = _deliveryAddress,
                    Lat     = _deliveryLat,
                    Lng     = _deliveryLng
                },
                Pickup = new LocationDto
                {
                    Address = _pickupAddress,
                    Lat     = _pickupLat,
                    Lng     = _pickupLng
                },
                Items = CartService.Items.Select(i => new CreateOrderItemDto
                {
                    ProductId = i.ProductId,
                    VariantId = i.VariantId == Guid.Empty ? null : i.VariantId,
                    Quantity  = i.Quantity
                }).ToList()
            };

            var result = await OrderService.AddOrder(request);

            if (result.Success)
            {
                ToastService.ShowToast("Order placed successfully!", string.Empty, ToastService.ToastLevel.Success);
                CartService.ClearCart();
                Navigation.NavigateTo("/customer/myorders");
                return;
            }

            ToastService.ShowToast(
                result.Error?.Message ?? "Failed to create order.",
                string.Empty, ToastService.ToastLevel.Error);
        }
        finally
        {
            _paying = false;
        }
    }
}
