@page "/customer/myorders"
@layout CustomerLayout
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject OrderService OrderService
@inject ToastService ToastService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "customer")]

<!-- ── Page header ── -->
<div class="d-flex align-center justify-space-between mb-6 flex-wrap gap-3">
    <MudText Typo="Typo.h5" Style="font-weight:800;">My Orders</MudText>
    <MudButton Href="/storefront" Variant="MudVariant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.ShoppingBag"
               Style="border-radius:8px; font-weight:700;">
        Shop More
    </MudButton>
</div>

<!-- ── Filters ── -->
<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="12" sm="6" md="4">
        <MudTextField @bind-Value="_search"
                      Placeholder="Search by address..."
                      Variant="MudVariant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Immediate="true" />
    </MudItem>
    <MudItem xs="12" sm="3" md="2">
        <SelectField TValue="string" TItem="string"
                     Label="Status"
                     Options="@_statusOptions"
                     @bind-Value="_statusFilter" />
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudDatePicker @bind-Date="_startDate" Label="From"
                       Variant="MudVariant.Outlined" Margin="Margin.Dense" />
    </MudItem>
    <MudItem xs="6" sm="3" md="2">
        <MudDatePicker @bind-Date="_endDate" Label="To"
                       Variant="MudVariant.Outlined" Margin="Margin.Dense" />
    </MudItem>
</MudGrid>

<!-- ── Grid ── -->
<AppGrid TItem="Order"
         Items="@FilteredOrders"
         Loading="@_loading"
         EmptyText="No orders found.">
    <ColDefs>
        <MudTh>Order</MudTh>
        <MudTh>Delivery</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Date</MudTh>
        <MudTh></MudTh>
    </ColDefs>
    <RowTemplate Context="order">
        <MudTd>
            <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:600;">
                #@order.Id.ToString()[..8]
            </MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Qty: @order.Quantity</MudText>
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.body2">@order.DeliveryAddress</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">↳ @order.PickupAddress</MudText>
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Variant="MudVariant.Filled" Label="true"
                     Color="@GetStatusColor(order.Status)">
                @order.Status
            </MudChip>
        </MudTd>
        <MudTd>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @order.CreatedAt.ToString("MMM d, yyyy")
            </MudText>
        </MudTd>
        <MudTd>
            <span @onclick:stopPropagation="true" class="d-inline-flex gap-1">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                               Color="Color.Default"
                               OnClick="@(() => OpenModal(order, editMode: false))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="@(() => OpenModal(order, editMode: true))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => ConfirmDelete(order))" />
            </span>
        </MudTd>
    </RowTemplate>
</AppGrid>

<!-- ── View / Edit dialog ── -->
<MudDialog @bind-IsVisible="_modalOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                Order #@(_selectedOrder?.Id.ToString()[..8])
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_editMode)
        {
            <MudTextField @bind-Value="_editDelivery" Label="Delivery Address"
                          Variant="MudVariant.Outlined" FullWidth="true" Class="mb-4" />
            <MudTextField @bind-Value="_editPickup" Label="Pickup Address"
                          Variant="MudVariant.Outlined" FullWidth="true" Class="mb-4" />
            <SelectField TValue="string" TItem="string"
                         Label="Status"
                         Options="@_statusOptions"
                         @bind-Value="_editStatus" />
        }
        else
        {
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.LocalShipping">
                    <MudText Typo="Typo.body2"><strong>Delivery:</strong> @_selectedOrder?.DeliveryAddress</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Store">
                    <MudText Typo="Typo.body2"><strong>Pickup:</strong> @_selectedOrder?.PickupAddress</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Circle">
                    <MudText Typo="Typo.body2"><strong>Status:</strong> @_selectedOrder?.Status</MudText>
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.DateRange">
                    <MudText Typo="Typo.body2">
                        <strong>Placed:</strong> @_selectedOrder?.CreatedAt.ToString("MMM d, yyyy HH:mm")
                    </MudText>
                </MudListItem>
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        @if (!_editMode)
        {
            <MudButton Variant="MudVariant.Outlined" StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="@(() => _editMode = true)">Edit</MudButton>
        }
        else
        {
            <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                       OnClick="SaveChanges" Disabled="@_saving">
                @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Save
            </MudButton>
        }
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _modalOpen = false)">Close</MudButton>
    </DialogActions>
</MudDialog>

<!-- ── Delete confirm dialog ── -->
<MudDialog @bind-IsVisible="_deleteOpen">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">Cancel Order</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1">
            Are you sure you want to cancel order <strong>#@_deleteTargetId.ToString()[..8]</strong>?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="MudVariant.Filled" Color="Color.Error"
                   OnClick="DeleteOrder" Disabled="@_saving">Cancel Order</MudButton>
        <MudButton Variant="MudVariant.Text" OnClick="@(() => _deleteOpen = false)">Keep</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public Guid? UserId { get; set; }

    private List<Order>? _orders;
    private bool    _loading      = true;
    private string  _search       = string.Empty;
    private string  _statusFilter = string.Empty;
    private DateTime? _startDate;
    private DateTime? _endDate;

    // Modal
    private bool    _modalOpen = false;
    private bool    _editMode  = false;
    private bool    _saving    = false;
    private Order?  _selectedOrder;
    private string  _editDelivery = string.Empty;
    private string  _editPickup   = string.Empty;
    private string  _editStatus   = string.Empty;

    // Delete
    private bool _deleteOpen     = false;
    private Guid _deleteTargetId;

    private static readonly List<string> _statusOptions =
        new[] { "" }.Concat(Enum.GetNames<OrderStatus>()).ToList();

    private IEnumerable<Order> FilteredOrders =>
        _orders?.Where(o =>
            (string.IsNullOrWhiteSpace(_search) ||
             o.PickupAddress.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
             o.DeliveryAddress.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(_statusFilter) ||
             o.Status.ToString().Equals(_statusFilter, StringComparison.OrdinalIgnoreCase)) &&
            (!_startDate.HasValue || o.CreatedAt.Date >= _startDate.Value.Date) &&
            (!_endDate.HasValue   || o.CreatedAt.Date <= _endDate.Value.Date)
        ) ?? Enumerable.Empty<Order>();

    protected override async Task OnInitializedAsync()
    {
        if (UserId.HasValue)
        {
            var result = await OrderService.GetOrdersByCustomer(UserId.Value);
            _orders = result.Success && result.Data != null ? result.Data : new();
        }
        else
        {
            _orders = new();
        }
        _loading = false;
    }

    private async Task Reload()
    {
        if (!UserId.HasValue) return;
        var result = await OrderService.GetOrdersByCustomer(UserId.Value);
        if (result.Success && result.Data != null) _orders = result.Data;
    }

    private void OpenModal(Order order, bool editMode)
    {
        _selectedOrder = order;
        _editDelivery  = order.DeliveryAddress;
        _editPickup    = order.PickupAddress;
        _editStatus    = order.Status.ToString();
        _editMode      = editMode;
        _modalOpen     = true;
    }

    private async Task SaveChanges()
    {
        if (_selectedOrder is null) return;
        _saving = true;

        bool changed = false;

        if (_editDelivery != _selectedOrder.DeliveryAddress)
        {
            await OrderService.UpdateOrder(_selectedOrder.Id,
                new UpdateOrderRequest { Column = "DeliveryLocation", Value = _editDelivery });
            changed = true;
        }
        if (_editPickup != _selectedOrder.PickupAddress)
        {
            await OrderService.UpdateOrder(_selectedOrder.Id,
                new UpdateOrderRequest { Column = "PickupLocation", Value = _editPickup });
            changed = true;
        }
        if (_editStatus != _selectedOrder.Status.ToString())
        {
            await OrderService.UpdateOrder(_selectedOrder.Id,
                new UpdateOrderRequest { Column = "OrderStatus", Value = _editStatus });
            changed = true;
        }

        _saving = false;

        if (changed)
        {
            await Reload();
            ToastService.ShowToast("Order updated.", string.Empty, ToastService.ToastLevel.Success);
        }
        else
        {
            ToastService.ShowToast("No changes were made.", string.Empty, ToastService.ToastLevel.Warning);
        }

        _modalOpen = false;
    }

    private void ConfirmDelete(Order order)
    {
        _deleteTargetId = order.Id;
        _deleteOpen     = true;
    }

    private async Task DeleteOrder()
    {
        _saving = true;
        var result = await OrderService.DeleteOrder(_deleteTargetId);
        _saving     = false;
        _deleteOpen = false;

        if (result.Success)
        {
            await Reload();
            ToastService.ShowToast("Order cancelled.", string.Empty, ToastService.ToastLevel.Success);
        }
        else
        {
            ToastService.ShowToast(result.Error?.Message ?? "Failed to cancel order.", string.Empty, ToastService.ToastLevel.Error);
        }
    }

    private static Color GetStatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Delivered  => Color.Success,
        OrderStatus.Pending    => Color.Warning,
        OrderStatus.Cancelled  => Color.Error,
        _                      => Color.Default,
    };
}
