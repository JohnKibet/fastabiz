@page "/customer/dashboard"
@layout CustomerLayout
@using frontend.Models
@using frontend.Models.Storefront
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject CartService CartService
@inject OrderService OrderService
@inject NavigationManager Navigation

<!-- ── Welcome banner ── -->
@if (_showWelcome)
{
    <MudAlert Severity="Severity.Success" Class="mb-6" Dense="true" ShowCloseIcon="true"
              CloseIconClicked="@(() => _showWelcome = false)">
        Welcome back, <strong>@_firstName</strong>! Here's your activity at a glance.
    </MudAlert>
}

<!-- ── Metric cards ── -->
<MudGrid Spacing="4" Class="mb-8">
    <MudItem xs="12" sm="6" lg="3">
        <MetricCard Title="Total Orders"    Value="@_orders.Count.ToString()"
                    Icon="box" />
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MetricCard Title="Items in Cart"   Value="@CartService.Count.ToString()"
                    Icon="cart" />
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MetricCard Title="Pending Orders"  Value="@_orders.Count(o => o.Status == OrderStatus.Pending).ToString()"
                    Icon="clock"        Highlight="warning" />
    </MudItem>
    <MudItem xs="12" sm="6" lg="3">
        <MetricCard Title="Delivered"       Value="@_orders.Count(o => o.Status == OrderStatus.Delivered).ToString()"
                    Icon="truck"        Highlight="success" />
    </MudItem>
</MudGrid>

<!-- ── Quick actions ── -->
<MudGrid Spacing="3" Class="mb-8">
    @foreach (var action in _actions)
    {
        <MudItem xs="6" sm="3">
            <MudButton Variant="MudVariant.Filled" Color="@action.Color" FullWidth="true"
                       StartIcon="@action.Icon" OnClick="@(() => Navigation.NavigateTo(action.Href))"
                       Style="border-radius:10px; font-weight:700; padding:14px 8px; height:64px;">
                @action.Label
            </MudButton>
        </MudItem>
    }
</MudGrid>

<!-- ── Recent orders ── -->
<MudPaper Elevation="2" Class="pa-6 rounded-xl mb-8">
    <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Recent Orders</MudText>

    <AppGrid TItem="Order"
             Items="@_orders.OrderByDescending(o => o.CreatedAt).Take(5)"
             Loading="@_loading"
             Dense="true"
             EmptyText="You haven't placed any orders yet."
             OnRowClick="@(o => Navigation.NavigateTo($"/customer/myorders"))">
        <ColDefs>
            <MudTh>Order ID</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Date</MudTh>
        </ColDefs>
        <RowTemplate Context="order">
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:600;">
                    #@order.Id.ToString()[..8]
                </MudText>
            </MudTd>
            <MudTd>@order.Quantity</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="MudVariant.Filled" Label="true"
                         Color="@GetStatusColor(order.Status)">
                    @order.Status
                </MudChip>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @order.CreatedAt.ToString("MMM dd, yyyy")
                </MudText>
            </MudTd>
        </RowTemplate>
    </AppGrid>
</MudPaper>

<!-- ── Recommended products ── -->
@if (_products.Any())
{
    <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Recommended Products</MudText>
    <MudGrid Spacing="4">
        @foreach (var product in _products)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="2" Class="rounded-xl store-card" Style="height:100%;">
                    <MudCardMedia Image="@product.ImageUrl" Height="160" />
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">@product.Name</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight:800; color:#16a34a;">
                            @((product.HasVariants ? product.MinPrice : product.Price)?.ToString("C"))
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="MudVariant.Filled" Color="Color.Primary" FullWidth="true"
                                   OnClick="@(() => Navigation.NavigateTo($"/product/{product.Id}"))"
                                   Style="border-radius:0 0 12px 12px; font-weight:700;">
                            View
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [CascadingParameter] public Guid?   UserId   { get; set; }
    [CascadingParameter] public string? UserName { get; set; }

    private string _firstName => string.IsNullOrWhiteSpace(UserName) ? "there"
        : UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";

    private bool                  _showWelcome = true;
    private bool                  _loading     = true;
    private List<Order>           _orders      = new();
    private List<ProductListItem> _products    = new();

    private record QuickAction(string Label, string Href, string Icon, Color Color);
    private readonly QuickAction[] _actions = new[]
    {
        new QuickAction("Shop",          "/storefront",          Icons.Material.Filled.ShoppingBag,    Color.Primary),
        new QuickAction("My Orders",     "/customer/myorders",   Icons.Material.Filled.ListAlt,        Color.Secondary),
        new QuickAction("Track Order",   "/customer/trackorder", Icons.Material.Filled.LocationOn,     Color.Warning),
        new QuickAction("Feedback",      "/customer/feedback",   Icons.Material.Filled.StarRate,       Color.Default),
    };

    protected override async Task OnInitializedAsync()
    {
        // Auto-dismiss welcome after 5 s
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            _showWelcome = false;
            InvokeAsync(StateHasChanged);
        });

        if (UserId.HasValue)
        {
            var result = await OrderService.GetOrdersByCustomer(UserId.Value);
            if (result.Success && result.Data != null)
                _orders = result.Data;
        }

        // TODO: replace with real featured-products endpoint
        _loading = false;
    }

    private static Color GetStatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Delivered  => Color.Success,
        OrderStatus.Pending    => Color.Warning,
        OrderStatus.Cancelled  => Color.Error,
        _                      => Color.Default,
    };
}
