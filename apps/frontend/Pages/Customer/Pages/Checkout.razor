@page "/customer/checkout"
@layout CustomerLayout
@using frontend.Models
@using frontend.Pages.Shared.Components.Cart
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@inject CartService CartService
@inject NavigationManager Navigation

<!-- ── Page header ── -->
<div class="d-flex align-center justify-space-between mb-6">
    <MudText Typo="Typo.h5" Style="font-weight:800;">Checkout</MudText>
    <MudChip T="string" Size="Size.Small" Variant="MudVariant.Filled" Color="Color.Primary" Label="true">
        @CartService.TotalQuantity item@(CartService.TotalQuantity == 1 ? "" : "s")
    </MudChip>
</div>

@if (!CartService.Items.Any())
{
    <!-- Empty state -->
    <MudPaper Elevation="2" Class="pa-10 rounded-xl d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCartCheckout"
                 Style="font-size:4rem; color:#d1d5db;" Class="mb-4" />
        <MudText Typo="Typo.h6" Style="color:#374151;" Class="mb-2">Your cart is empty</MudText>
        <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                   OnClick="@(() => Navigation.NavigateTo("/storefront"))"
                   Style="border-radius:8px; font-weight:700;">
            Shop Now
        </MudButton>
    </MudPaper>
}
else
{
    <MudGrid Spacing="5">

        <!-- Cart items -->
        <MudItem xs="12" lg="5">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">
                <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Your Cart</MudText>
                <CartCard />
            </MudPaper>
        </MudItem>

        <!-- Delivery / map section -->
        <MudItem xs="12" lg="7">
            <MudPaper Elevation="2" Class="pa-6 rounded-xl">

                <!-- Actions row -->
                <div class="d-flex align-center justify-space-between mb-5 flex-wrap gap-2">
                    <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Home"
                               OnClick="UseUsualAddresses"
                               Style="border-radius:8px; font-weight:600;">
                        Use usual addresses
                    </MudButton>
                    <MudButton Variant="MudVariant.Outlined" Color="Color.Default"
                               StartIcon="@(_showMap ? Icons.Material.Filled.OutlinedFlag : Icons.Material.Filled.Map)"
                               OnClick="@(() => _showMap = !_showMap)"
                               Style="border-radius:8px; font-weight:600;">
                        @(_showMap ? "Hide Map" : "Show Map")
                    </MudButton>
                </div>

                <!-- Delivery input -->
                <div class="d-flex align-center gap-3 mb-4">
                    <MudButton Variant="@(_isDeliveryMode ? MudVariant.Filled : MudVariant.Outlined)"
                               Color="Color.Secondary" Size="Size.Small"
                               OnClick="@(() => SetMode(DeliveryMode.Delivery))"
                               Disabled="@(!_showMap)"
                               Style="border-radius:6px; font-weight:600; min-width:80px;">
                        Delivery
                    </MudButton>
                    <MudTextField @bind-Value="_deliveryAddress"
                                  Placeholder="Delivery address"
                                  Variant="MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  Disabled="@(!_isDeliveryMode || !_showMap)"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.LocalShipping" />
                </div>

                <!-- Pickup input -->
                <div class="d-flex align-center gap-3 mb-5">
                    <MudButton Variant="@(_isPickupMode ? MudVariant.Filled : MudVariant.Outlined)"
                               Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => SetMode(DeliveryMode.Pickup))"
                               Disabled="@(!_showMap)"
                               Style="border-radius:6px; font-weight:600; min-width:80px;">
                        Pickup
                    </MudButton>
                    <MudTextField @bind-Value="_pickupAddress"
                                  Placeholder="Pickup location"
                                  Variant="MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  Disabled="@(!_isPickupMode || !_showMap)"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Store" />
                </div>

                @if (_showMap)
                {
                    <!-- Map placeholder — swap for <CustomerMap /> when ready -->
                    <MudPaper Elevation="0" Class="rounded-xl d-flex align-center justify-center"
                              Style="height:260px; background:#f9fafb; border:2px dashed #e5e7eb;">
                        <div class="d-flex flex-column align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Map" Style="font-size:3rem; color:#d1d5db;" />
                            <MudText Typo="Typo.body2" Style="color:#9ca3af;">Map will appear here</MudText>
                        </div>
                    </MudPaper>
                }

                <!-- Order total + proceed -->
                <MudDivider Class="my-5" />
                <div class="d-flex align-center justify-space-between mb-4">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">
                        Total (@CartService.TotalQuantity item@(CartService.TotalQuantity == 1 ? "" : "s"))
                    </MudText>
                    <MudText Typo="Typo.h6" Style="font-weight:800; color:#16a34a;">
                        @CartService.Total.ToString("C")
                    </MudText>
                </div>

                <MudButton Variant="MudVariant.Filled" Color="Color.Primary"
                           FullWidth="true" Size="Size.Large"
                           OnClick="GoToPayment"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           Style="border-radius:10px; font-weight:700;">
                    Proceed to Payment
                </MudButton>

            </MudPaper>
        </MudItem>

    </MudGrid>
}

@code {
    private enum DeliveryMode { Delivery, Pickup }

    private DeliveryMode _mode = DeliveryMode.Delivery;
    private string _deliveryAddress = string.Empty;
    private string _pickupAddress   = string.Empty;
    private bool   _showMap         = true;

    // Hardcoded MVP defaults — replace with user profile addresses
    private const string DefaultDelivery = "Kenyatta Avenue, CBD, Nairobi";
    private const string DefaultPickup   = "Accra Road, CBD, Nairobi";

    private bool _isDeliveryMode => _mode == DeliveryMode.Delivery;
    private bool _isPickupMode   => _mode == DeliveryMode.Pickup;

    private void SetMode(DeliveryMode mode) => _mode = mode;

    private void UseUsualAddresses()
    {
        _deliveryAddress = DefaultDelivery;
        _pickupAddress   = DefaultPickup;
        _showMap         = false;
    }

    private void GoToPayment()
    {
        // Fall back to defaults if the user skipped address entry
        if (string.IsNullOrWhiteSpace(_deliveryAddress)) _deliveryAddress = DefaultDelivery;
        if (string.IsNullOrWhiteSpace(_pickupAddress))   _pickupAddress   = DefaultPickup;

        // Hardcoded coordinates for MVP — replace with map pin values
        const string delLat  = "-1.2848242046310998";
        const string delLng  = "36.82204128701168";
        const string pickLat = "-1.2829256773845723";
        const string pickLng = "36.827309307951396";

        Navigation.NavigateTo(
            $"/customer/payment" +
            $"?delivery={Uri.EscapeDataString(_deliveryAddress)}" +
            $"&pickup={Uri.EscapeDataString(_pickupAddress)}" +
            $"&delLat={delLat}&delLng={delLng}" +
            $"&pickLat={pickLat}&pickLng={pickLng}");
    }
}
