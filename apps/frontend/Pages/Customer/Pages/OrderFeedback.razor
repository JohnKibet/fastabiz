@page "/customer/feedback"
@layout CustomerLayout
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject FeedbackService FeedbackService
@inject ToastService ToastService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "customer")]

<div style="max-width:600px;">
    <AppForm Title="Rate Your Delivery"
             Subtitle="Help us improve by sharing your experience"
             Model="@_feedback"
             OnValidSubmit="HandleSubmit"
             OnCancel="@(() => Navigation.NavigateTo("/customer/myorders"))"
             SubmitLabel="Submit Feedback"
             Loading="@_saving"
             Error="@_error">

        <MudTextField @bind-Value="_orderIdText"
                      Label="Order ID"
                      Placeholder="Paste your order ID here"
                      Variant="MudVariant.Outlined"
                      FullWidth="true"
                      Class="mb-4"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Receipt" />

        <MudTextField @bind-Value="_feedback.Comment"
                      Label="Your Feedback"
                      Placeholder="Tell us about your delivery experience..."
                      Variant="MudVariant.Outlined"
                      FullWidth="true"
                      Lines="5"
                      Class="mb-4" />

    </AppForm>
</div>

@code {
    private CreateFeedbackRequest _feedback = new();
    private string  _orderIdText = string.Empty;
    private bool    _saving      = false;
    private string? _error;

    private async Task HandleSubmit()
    {
        _error = null;

        if (!Guid.TryParse(_orderIdText, out var orderId))
        {
            _error = "Invalid Order ID — paste the full UUID from your order confirmation.";
            return;
        }

        _feedback.OrderID = orderId;
        _saving = true;

        var result = await FeedbackService.CreateFeedback(_feedback);
        _saving = false;

        if (result.Success)
        {
            ToastService.ShowToast("Feedback submitted — thank you!", string.Empty, ToastService.ToastLevel.Success);
            Navigation.NavigateTo("/customer/myorders");
            return;
        }

        _error = result.Error?.Message ?? "Failed to submit feedback.";
    }
}
