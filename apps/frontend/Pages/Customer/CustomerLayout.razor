@inherits LayoutComponentBase
@namespace frontend.Pages.Customer
@using frontend.Pages.Shared.Layout
@using frontend.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject CartService CartService

@*
    CustomerLayout sits between LayoutComponentBase and AuthorizedLayout.

    Responsibilities:
      1. Rehydrate the cart from localStorage on first load so items
         persist across page navigations and browser refreshes.
      2. Any customer-specific cascading values go here.

    AppTheme, MudSnackbarProvider, MudDialogProvider are provided by
    AuthorizedLayout — do not add them here.
*@

<AuthorizedLayout>
    @Body
</AuthorizedLayout>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask == null) return;

        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        // Rehydrate cart from localStorage on every layout mount.
        // CartService is a Singleton — LoadCartAsync is idempotent
        // (re-deserialises the same data) so calling it here is safe
        // even if the user navigates between customer pages.
        await CartService.LoadCartAsync();
    }
}
