@namespace frontend.Pages.Shared.Components.Merchant
@using frontend.Models
@using frontend.Models.Storefront
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs.SelectField
@using frontend.Configs.AppForm
@inject ProductService ProductService
@inject StoreService StoreService
@inject ToastService ToastService
@inject NavigationManager Navigation

@* ── Store selector (shown when StoreId not injected via param) ── *@
@if (!StoreId.HasValue)
{
    <MudPaper Elevation="2" Class="pa-5 rounded-xl mb-6">
        <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight:700;">Select Store</MudText>
        @if (_loadingStores)
        {
            <MudSkeleton Height="40px" />
        }
        else if (_stores.Count == 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">
                You don't have any stores yet.
                <MudLink Href="/merchant/stores/create" Color="Color.Primary">Create one</MudLink>
            </MudAlert>
        }
        else
        {
            <SelectField Label="Store"                         TValue="Guid"                         TItem="StoreDto" Items="@_stores" Value="@(_selectedStoreId ?? Guid.Empty)"
                         ValueChanged="OnStoreSelected" ItemValue="@(s => s.Id)" ItemText="@(s => s.Name)" />
        }
    </MudPaper>
}

@* ── Step 1: Core product details ── *@
<AppForm Title="Create Product" Subtitle="Add a product to your store"     Model="@_product"     OnValidSubmit="Submit"
         OnCancel="@(() => Navigation.NavigateTo("/merchant/products"))" SubmitLabel="Create Product"  Loading="@_saving"
         Error="@_error">

    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudTextField @bind-Value="_product.Name"                Label="Product Name"                         Variant="MudVariant.Outlined"
                          FullWidth="true" For="@(() => _product.Name)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <SelectField Label="Category"                 TValue="string"       TItem="string"               Options="@_categories"
                         @bind-Value="_product.Category"              For="@(() => _product.Category)" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_product.Description"                       Label="Description"               Variant="MudVariant.Outlined"
                          FullWidth="true"                          Lines="4"                          For="@(() => _product.Description)" />
        </MudItem>
        <MudItem xs="12">
            <MudCheckBox @bind-Value="_product.HasVariants" Color="Color.Primary"
                         Label="This product has variants (sizes, colours, etc.)" />
        </MudItem>
    </MudGrid>

</AppForm>

@* ── Step 2a: Simple product — price & stock ── *@
@if (_productCreated && !_product.HasVariants)
{
    <MudPaper Elevation="2" Class="pa-6 rounded-xl mt-6">
        <MudText Typo="Typo.h6" Style="font-weight:700;" Class="mb-4">Price &amp; Stock</MudText>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_product.Price"                                 Label="Price" Variant="MudVariant.Outlined" FullWidth="true"
                                 Min="0" Format="F2"            Adornment="Adornment.Start"          AdornmentText="$"         Disabled="@_inventorySaved" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_product.Stock"                   Label="Stock"                  Variant="MudVariant.Outlined"                FullWidth="true"
                                 Min="0"                                Disabled="@_inventorySaved" />
            </MudItem>
        </MudGrid>

        @if (!_inventorySaved)
        {
            <MudButton OnClick="UpdateInventory" Variant="MudVariant.Filled" Color="Color.Primary"          Class="mt-4"
                       Style="border-radius:8px; font-weight:700;"                       Loading="@_savingInventory">
                Save Price &amp; Stock
            </MudButton>
        }
        else
        {
            <div class="d-flex align-center gap-3 mt-4">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText Typo="Typo.body2" Style="color:#16a34a; font-weight:600;">Inventory saved</MudText>
                <MudButton Variant="MudVariant.Text" Color="Color.Primary" OnClick="ResetAll">
                    Create another product
                </MudButton>
            </div>
        }
    </MudPaper>
}

@* ── Step 2b: Variant product ── *@
@if (_productCreated && _product.HasVariants)
{
    <VariantSection @ref="_variantSection"                    ProductId="@_createdProductId"                    OnVariantCreated="@(() => _hasVariants = true)" />

    @if (_hasVariants)
    {
        <div class="d-flex align-center justify-space-between mt-6">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Done adding variants?</MudText>
            <MudButton Variant="MudVariant.Text" Color="Color.Primary" OnClick="ResetAll">
                Create another product
            </MudButton>
        </div>
    }
}

@code {
    [CascadingParameter] ActiveStoreContext? ActiveStore { get; set; }
    [Parameter] public Guid? StoreId { get; set; }

    private CreateProductRequest _product = new();
    private List<StoreDto> _stores = new();
    private Guid? _selectedStoreId;
    private bool _loadingStores = true;
    private bool _saving = false;
    private bool _savingInventory = false;
    private bool _productCreated = false;
    private bool _inventorySaved = false;
    private bool _hasVariants = false;
    private Guid _createdProductId;
    private string? _error;

    private VariantSection? _variantSection;

    // Drives the Category SelectField — replace with API call if categories are dynamic
    private readonly List<string> _categories = new()
    {
        "Produce", "Dairy", "Bakery", "Beverages", "Meat",
        "Seafood", "Frozen", "Snacks", "Household", "Other"
    };

    protected override async Task OnInitializedAsync()
    {
        var result = await StoreService.GetAllStores();
        if (result.Success && result.Data != null)
            _stores = result.Data;
        _loadingStores = false;
    }

    protected override void OnParametersSet()
    {
        if (StoreId.HasValue && StoreId != Guid.Empty)
        {
            _selectedStoreId = StoreId;
            _product.StoreId = StoreId.Value;
        }
    }

    private void OnStoreSelected(Guid id)
    {
        _selectedStoreId = id;
        _product.StoreId = id;
        Navigation.NavigateTo($"/merchant/products/create/{id}", replace: true);
    }

    private async Task Submit()
    {
        _error = null;
        _saving = true;

        // Prefer cascaded ActiveStore over the param — keeps it consistent with
        // the rest of the merchant shell
        if (ActiveStore is not null && ActiveStore.StoreId != Guid.Empty)
            _product.StoreId = ActiveStore.StoreId;

        if (_product.StoreId == Guid.Empty)
        {
            ToastService.ShowToast("Please select a store first.", "", ToastService.ToastLevel.Warning);
            _saving = false;
            return;
        }

        var result = await ProductService.AddProduct(_product);
        _saving = false;

        if (!result.Success || result.Data is null)
        {
            _error = result.Error?.Detail ?? "Failed to create product.";
            return;
        }

        _createdProductId = result.Data.Id;
        _productCreated = true;

        ToastService.ShowToast(
            _product.HasVariants
                ? "Product created — now add variants."
                : "Product created — now set price and stock.",
            "", ToastService.ToastLevel.Success);
    }

    private async Task UpdateInventory()
    {
        if (_product.Price <= 0 || _product.Stock < 0)
        {
            ToastService.ShowToast("Enter a valid price and stock.", "", ToastService.ToastLevel.Warning);
            return;
        }

        _savingInventory = true;

        var result = await ProductService.UpdateProductInventory(new UpdateProductInventoryRequest
        {
            ProductId = _createdProductId,
            Price = _product.Price,
            Stock = _product.Stock
        });

        _savingInventory = false;

        if (!result.Success)
        {
            ToastService.ShowToast(result.Error?.Detail ?? "Failed to update inventory.", "", ToastService.ToastLevel.Error);
            return;
        }

        _inventorySaved = true;
        ToastService.ShowToast(result.Data?.Message ?? "Inventory saved.", "", ToastService.ToastLevel.Success);
    }

    private void ResetAll()
    {
        _product = new CreateProductRequest();
        _productCreated = false;
        _inventorySaved = false;
        _saving = false;
        _savingInventory = false;
        _createdProductId = Guid.Empty;
        _hasVariants = false;
        _error = null;
        _variantSection?.ResetAll();
    }
}