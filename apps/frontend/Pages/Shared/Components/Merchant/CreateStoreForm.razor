@namespace frontend.Pages.Shared.Components.Merchant
@using frontend.Models
@using frontend.Models.Storefront
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject StoreService StoreService
@inject ToastService ToastService
@inject NavigationManager Navigation

<AppForm Title="Create Store"
         Subtitle="Set up your storefront details"
         Model="@_store"
         OnValidSubmit="HandleValidSubmit"
         OnCancel="@(() => Navigation.NavigateTo("/merchant/stores"))"
         SubmitLabel="Create Store"
         Loading="@_saving"
         Error="@_error">

    <MudTextField @bind-Value="_store.Name"
                  Label="Store Name"
                  Variant="MudVariant.Outlined"
                  FullWidth="true"
                  Class="mb-4"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Store"
                  For="@(() => _store.Name)" />

    <MudTextField @bind-Value="_store.Location"
                  Label="Location"
                  Variant="MudVariant.Outlined"
                  FullWidth="true"
                  Class="mb-4"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.LocationOn"
                  For="@(() => _store.Location)" />

    <MudTextField @bind-Value="_store.Logo"
                  Label="Logo URL"
                  Variant="MudVariant.Outlined"
                  FullWidth="true"
                  Class="mb-4"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Image"
                  Placeholder="https://..." />

</AppForm>

@code {
    private CreateStoreRequest _store = new() { Id = Guid.NewGuid() };
    private bool    _saving = false;
    private string? _error;

    private async Task HandleValidSubmit()
    {
        _error  = null;
        _saving = true;

        try
        {
            var result = await StoreService.CreateStore(_store);

            if (result.Success)
            {
                ToastService.ShowToast("Store created successfully", string.Empty, ToastService.ToastLevel.Success);
                Navigation.NavigateTo($"/merchant/products/create/{_store.Id}");
                return;
            }

            _error = result.Error?.Message ?? "Failed to create store.";
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
