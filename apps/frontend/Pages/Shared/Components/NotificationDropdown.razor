@using frontend.Models
@using frontend.Services
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using MudIcons = MudBlazor.Icons
@inject NotificationService NotificationService
@inject ToastService ToastService
@inject CustomAuthStateProvider AuthProvider
@inject NavigationManager Navigation

@*
    NOTIFICATION MENU
    ─────────────────────────────────────────────────────────────────
    ActivatorContent must use a MudBlazor interactive component.
    The original implementation used a plain <div> wrapping a MudIcon
    and a MudBadge. Plain <div>s do not forward pointer events to
    MudMenu's internal toggle — the menu never opened.

    Fix: MudIconButton as the activator. The badge is positioned
    absolutely over the button using a wrapper div, which is fine
    because the wrapper is purely visual and the button still receives
    the click. Alternatively MudBadge can wrap MudIconButton directly.
    ─────────────────────────────────────────────────────────────────
*@

<MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="mx-1">
    <ActivatorContent>
        @*
            MudBadge wrapping MudIconButton:
            MudBadge is a layout wrapper — it does not block pointer events.
            The click hits MudIconButton first, which MudMenu knows to listen
            to, so the menu opens correctly.
        *@
        <MudBadge Content="@(UnreadCount > 0 ? UnreadCount.ToString() : null)"
                  Color="Color.Error"
                  Overlap="true"
                  Bordered="true"
                  Visible="@(UnreadCount > 0)">
            <MudIconButton Icon="@MudIcons.Material.Filled.Notifications"
                           Color="@(UnreadCount > 0 ? Color.Warning : Color.Default)"
                           Size="Size.Medium" />
        </MudBadge>
    </ActivatorContent>

    <ChildContent>
        <!-- Header -->
        <div class="d-flex align-center justify-space-between px-4 py-2"
             style="min-width:300px; border-bottom:1px solid #e5e7eb;">
            <MudText Typo="Typo.subtitle2" Style="font-weight:700; color:#111827;">Notifications</MudText>
            @if (notifications.Any())
            {
                <MudButton Variant="MudVariant.Text" Color="Color.Warning" Size="Size.Small"
                           OnClick="MarkAllAsRead" Style="font-weight:600; font-size:0.75rem;">
                    Mark all read
                </MudButton>
            }
        </div>

        <!-- List -->
        @if (notifications.Any())
        {
            @foreach (var note in notifications.Take(5))
            {
                <MudMenuItem Style="padding:10px 14px; white-space:normal; max-width:320px;">
                    <div class="d-flex align-start gap-3">
                        <MudAvatar Color="@(note.Status == NotificationStatus.Read ? Color.Default : Color.Primary)"
                                   Size="Size.Small"
                                   Style="width:30px; height:30px; flex-shrink:0; font-size:0.75rem;">
                            <MudIcon Icon="@MudIcons.Material.Filled.NotificationsActive" Size="Size.Small" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2"
                                     Style="@($"color:#374151; font-weight:{(note.Status != NotificationStatus.Read ? "600" : "400")}; line-height:1.4; white-space:normal;")">
                                @note.Message
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:#9ca3af;">
                                @note.SentAt.ToShortTimeString()
                            </MudText>
                        </div>
                    </div>
                </MudMenuItem>
                <MudDivider />
            }
        }
        else
        {
            <div class="d-flex flex-column align-center py-6 px-4">
                <MudIcon Icon="@MudIcons.Material.Outlined.NotificationsNone"
                         Style="font-size:2.5rem; color:#d1d5db;" Class="mb-2" />
                <MudText Typo="Typo.body2" Style="color:#9ca3af;">No notifications yet</MudText>
            </div>
        }

        <!-- Footer -->
        <div style="border-top:1px solid #e5e7eb; padding:8px 14px;">
            <MudButton Variant="MudVariant.Text" Color="Color.Primary" FullWidth="true" Size="Size.Small"
                       OnClick='() => Navigation.NavigateTo("/merchant/notifications")'
                       Style="font-weight:600;">
                View All History
            </MudButton>
        </div>
    </ChildContent>
</MudMenu>

@code {
    [CascadingParameter] public Guid? UserId { get; set; }

    private List<Notification> notifications = new();
    private int UnreadCount;

    protected override async Task OnInitializedAsync() => await LoadNotifications();

    private async Task LoadNotifications()
    {
        if (!UserId.HasValue) return;
        var result = await NotificationService.GetNotificationByUser(UserId.Value);
        notifications = result.Data ?? [];
        UnreadCount   = notifications.Count(n => n.Status != NotificationStatus.Read);
    }

    private async Task MarkAllAsRead()
    {
        if (!UserId.HasValue) return;
        await NotificationService.MarkAllAsRead(UserId.Value);
        await LoadNotifications();
    }
}
