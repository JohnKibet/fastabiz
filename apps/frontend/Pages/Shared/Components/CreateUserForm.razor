@namespace frontend.Pages.Shared.Components.Merchant
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@using frontend.Configs
@inject UserService UserService
@inject ToastService ToastService
@inject NavigationManager Navigation

<AppForm Title="Create User"
         Subtitle="Add a new user to the platform"
         Model="@_user"
         OnValidSubmit="HandleValidSubmit"
         OnCancel="@(() => Navigation.NavigateTo("/merchant/users"))"
         SubmitLabel="Create User"
         Loading="@_saving"
         Error="@_error">

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_user.FullName"
                          Label="Full Name"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Placeholder="e.g. John Doe"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          For="@(() => _user.FullName)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_user.Email"
                          Label="Email"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Placeholder="e.g. john@example.com"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          For="@(() => _user.Email)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_user.Password"
                          Label="Password"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Placeholder="e.g. Pass1234"
                          InputType="@(_showPass ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPass ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="@(() => _showPass = !_showPass)"
                          For="@(() => _user.Password)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_user.Phone"
                          Label="Phone"
                          Variant="MudVariant.Outlined"
                          FullWidth="true"
                          Placeholder="e.g. 0712345678"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Phone"
                          For="@(() => _user.Phone)" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <SelectField TValue="string"
                         TItem="string"
                         Label="Role"
                         Options="@_roles"
                         @bind-Value="_user.Role"
                         For="@(() => _user.Role)" />
        </MudItem>
    </MudGrid>

</AppForm>

@code {
    private CreateUserRequest _user   = new();
    private bool    _saving   = false;
    private bool    _showPass = false;
    private string? _error;

    private static readonly List<string> _roles = new() { "merchant", "customer", "driver" };

    private async Task HandleValidSubmit()
    {
        _error  = null;
        _saving = true;

        try
        {
            var result = await UserService.AddUser(_user);

            if (result.Success)
            {
                ToastService.ShowToast("User created successfully!", string.Empty, ToastService.ToastLevel.Success);
                Navigation.NavigateTo("/merchant/users");
                return;
            }

            _error = result.Error?.Message ?? "Failed to create user.";
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
