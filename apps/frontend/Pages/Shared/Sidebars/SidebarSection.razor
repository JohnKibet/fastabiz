@using frontend.Models
@using MudBlazor

@if (IsSingleItem)
{
    <!-- Direct nav item — no collapsible wrapper -->
    <SidebarItem Item="Items[0]" IsCollapsed="IsCollapsed" HighlightSectionTitle="true" />
}
else
{
    <div style="margin-bottom:2px;">
        <!-- Section header -->
        <div class="@($"sidebar-section-header {(IsOpen ? "sidebar-section-open" : "")}")"
             @onclick="Toggle" role="button" tabindex="0" aria-expanded="@IsOpen" title="@Title">

            <MudIcon Icon="@Icon" Size="Size.Small"
                     Style="@($"color:{(IsOpen ? "#16a34a" : "#6b7280")}; flex-shrink:0; font-size:1.1rem;")" />

            @if (!IsCollapsed)
            {
                <span class="sidebar-section-label">@Title</span>
                <MudIcon Icon="@(IsOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)"
                         Size="Size.Small" Style="color:#9ca3af; margin-left:auto; font-size:1rem;" />
            }
        </div>

        <!-- Dropdown items -->
        @if (IsOpen && !IsCollapsed)
        {
            <ul style="margin:2px 0 4px 16px; padding:0; list-style:none;">
                @foreach (var item in Items)
                {
                    <SidebarItem Item="item" IsCollapsed="IsCollapsed" />
                }
            </ul>
        }
    </div>
}

<style>
    .sidebar-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 8px;
        cursor: pointer;
        user-select: none;
        transition: background 0.15s;
        color: #374151;
    }
    .sidebar-section-header:hover {
        background: #f0fdf4;
        color: #16a34a;
    }
    .sidebar-section-open {
        background: #f0fdf4;
        color: #16a34a;
        font-weight: 600;
        border-left: 3px solid #16a34a;
        padding-left: 7px;
    }
    .sidebar-section-label {
        font-size: 0.8rem;
        font-weight: 600;
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: inherit;
    }
</style>

@code {
    private bool IsSingleItem => Items?.Count == 1;

    [Parameter] public string Title      { get; set; } = string.Empty;
    [Parameter] public string SectionKey { get; set; } = string.Empty;
    [Parameter] public string Icon       { get; set; } = string.Empty;
    [Parameter] public List<SidebarMenuItem> Items { get; set; } = new();
    [Parameter] public bool IsCollapsed  { get; set; }
    [Parameter] public bool IsOpen       { get; set; }
    [Parameter] public EventCallback<string> OnToggle { get; set; }

    private async Task Toggle() => await OnToggle.InvokeAsync(SectionKey);
}
