@using System.Security.Claims
@using Microsoft.AspNetCore.WebUtilities
@using frontend.Models
@using MudBlazor
@inject NavigationManager Navigation
@implements IDisposable

<MudDrawer @bind-Open="_open"
           Variant="DrawerVariant.Mini"
           MiniWidth="64px"
           Width="240px"
           Elevation="2"
           Style="background:#ffffff; border-right:1px solid #e5e7eb;">

    <!-- Header -->
    <MudDrawerHeader Style="padding:12px 12px; border-bottom:1px solid #e5e7eb; background:#f9fafb; min-height:56px;"
                     Class="d-flex align-center justify-space-between">
        @if (_open)
        {
            <MudText Typo="Typo.h6" Style="font-weight:800; color:#111827; letter-spacing:-0.3px;">FastaBiz</MudText>
        }
        <MudIconButton Icon="@(_open ? Icons.Material.Filled.ChevronLeft : Icons.Material.Filled.ChevronRight)"
                       Size="Size.Small"
                       Color="Color.Default"
                       OnClick="ToggleSidebar"
                       Style="margin-left:auto;" />
    </MudDrawerHeader>

    <!-- Nav -->
    <MudNavMenu Style="padding:8px 4px; flex:1; overflow-y:auto;">
        @if (Role == "merchant")
        {
            <SidebarSection Title="Dashboard"   Icon="@Icons.Material.Filled.Dashboard"        SectionKey="MerchantDashboard"   IsCollapsed="!_open" Items="MerchantDashboard"   IsOpen="@IsSectionOpen("MerchantDashboard")"   OnToggle="ToggleSection" />
            <SidebarSection Title="Operations"  Icon="@Icons.Material.Filled.SwapHoriz"        SectionKey="MerchantOperations"  IsCollapsed="!_open" Items="MerchantOperations"  IsOpen="@IsSectionOpen("MerchantOperations")"  OnToggle="ToggleSection" />
            <SidebarSection Title="Stores"      Icon="@Icons.Material.Filled.Warehouse"        SectionKey="MerchantStores"      IsCollapsed="!_open" Items="MerchantStores"      IsOpen="@IsSectionOpen("MerchantStores")"      OnToggle="ToggleSection" />
            <SidebarSection Title="Products"    Icon="@Icons.Material.Filled.Inventory2"       SectionKey="MerchantProducts"    IsCollapsed="!_open" Items="MerchantProducts"    IsOpen="@IsSectionOpen("MerchantProducts")"    OnToggle="ToggleSection" />
            <SidebarSection Title="Reports"     Icon="@Icons.Material.Filled.BarChart"         SectionKey="MerchantReports"     IsCollapsed="!_open" Items="MerchantReports"     IsOpen="@IsSectionOpen("MerchantReports")"     OnToggle="ToggleSection" />
            <SidebarSection Title="Users"       Icon="@Icons.Material.Filled.Group"            SectionKey="MerchantUsers"       IsCollapsed="!_open" Items="MerchantUsers"       IsOpen="@IsSectionOpen("MerchantUsers")"       OnToggle="ToggleSection" />
        }
        else if (Role == "driver")
        {
            <SidebarSection Title="Dashboard"        Icon="@Icons.Material.Filled.Dashboard"        SectionKey="DriverDashboard"   IsCollapsed="!_open" Items="DriverDashboardItems"  IsOpen="@IsSectionOpen("DriverDashboard")"   OnToggle="ToggleSection" />
            <SidebarSection Title="Deliveries"       Icon="@Icons.Material.Filled.LocalShipping"    SectionKey="DriverDeliveries"  IsCollapsed="!_open" Items="DriverDeliveriesItems" IsOpen="@IsSectionOpen("DriverDeliveries")"  OnToggle="ToggleSection" />
            <SidebarSection Title="Navigation"       Icon="@Icons.Material.Filled.Route"            SectionKey="DriverRoute"       IsCollapsed="!_open" Items="DriverRouteItems"      IsOpen="@IsSectionOpen("DriverRoute")"       OnToggle="ToggleSection" />
            <SidebarSection Title="Proof of Delivery" Icon="@Icons.Material.Filled.FactCheck"       SectionKey="DriverProof"       IsCollapsed="!_open" Items="DriverProofItems"      IsOpen="@IsSectionOpen("DriverProof")"       OnToggle="ToggleSection" />
        }
        else if (Role == "customer")
        {
            <SidebarSection Title="Dashboard"    Icon="@Icons.Material.Filled.Dashboard"        SectionKey="CustomerMenu"         IsCollapsed="!_open" Items="CustomerDashboard"   IsOpen="@IsSectionOpen("CustomerMenu")"         OnToggle="ToggleSection" />
            <SidebarSection Title="Orders"       Icon="@Icons.Material.Filled.ListAlt"          SectionKey="CustomerOrders"       IsCollapsed="!_open" Items="CustomerOrders"      IsOpen="@IsSectionOpen("CustomerOrders")"       OnToggle="ToggleSection" />
            <SidebarSection Title="Checkout"     Icon="@Icons.Material.Filled.ShoppingCartCheckout" SectionKey="CustomerCheckout" IsCollapsed="!_open" Items="CustomerCheckout"    IsOpen="@IsSectionOpen("CustomerCheckout")"     OnToggle="ToggleSection" />
            <SidebarSection Title="Payment"      Icon="@Icons.Material.Filled.CreditCard"       SectionKey="CustomerPayment"      IsCollapsed="!_open" Items="CustomerPayment"     IsOpen="@IsSectionOpen("CustomerPayment")"      OnToggle="ToggleSection" />
            <SidebarSection Title="Feedback"     Icon="@Icons.Material.Filled.ThumbUp"          SectionKey="CustomerFeedback"     IsCollapsed="!_open" Items="CustomerFeedback"    IsOpen="@IsSectionOpen("CustomerFeedback")"     OnToggle="ToggleSection" />
            <SidebarSection Title="Track Order"  Icon="@Icons.Material.Filled.LocationOn"       SectionKey="CustomerTrackOrder"   IsCollapsed="!_open" Items="CustomerTrackOrder"  IsOpen="@IsSectionOpen("CustomerTrackOrder")"   OnToggle="ToggleSection" />
        }
        else
        {
            <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">No menu for your role.</MudText>
        }
    </MudNavMenu>

    <!-- Footer -->
    <div style="border-top:1px solid #e5e7eb; background:#f9fafb; padding:10px 12px;">
        @if (_open)
        {
            <MudText Typo="Typo.caption" Style="color:#9ca3af;">© 2025 FastaBiz</MudText>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Copyright" Size="Size.Small" Style="color:#9ca3af; display:block; margin:auto;" />
        }
    </div>
</MudDrawer>

@code {
    [CascadingParameter] public string? UserRole { get; set; }
    [CascadingParameter] public ActiveProductContext ProductCtx { get; set; } = default!;
    [Parameter] public EventCallback<bool> OnCollapseChanged { get; set; }

    private bool _open = true;
    private string? Role;
    private HashSet<string> openSections = new();
    private Guid? CurrentProductId;
    private string? CurrentPath;
    private string? CurrentMode;

    private bool IsManageProductActive =>
        CurrentProductId.HasValue &&
        CurrentPath?.StartsWith("/merchant/products/", StringComparison.OrdinalIgnoreCase) == true &&
        CurrentMode == "edit";

    protected override async Task OnInitializedAsync()
    {
        Role = UserRole ?? "guest";
        Navigation.LocationChanged += HandleLocationChanged;
        UpdateRouteState();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateRouteState();
        StateHasChanged();
    }

    public void Dispose() => Navigation.LocationChanged -= HandleLocationChanged;

    private void ToggleSidebar()
    {
        _open = !_open;
        if (!_open) openSections.Clear();
        OnCollapseChanged.InvokeAsync(!_open);
    }

    private void ToggleSection(string key)
    {
        if (openSections.Contains(key)) openSections.Remove(key);
        else openSections.Add(key);
        StateHasChanged();
    }

    private bool IsSectionOpen(string key) => openSections.Contains(key);

    private void UpdateRouteState()
    {
        var uri = new Uri(Navigation.Uri);
        CurrentPath = uri.AbsolutePath;
        var segments = uri.AbsolutePath.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length == 3 && segments[0] == "merchant" && segments[1] == "products" && Guid.TryParse(segments[2], out var id))
            CurrentProductId = id;
        else
            CurrentProductId = null;
        var query = QueryHelpers.ParseQuery(uri.Query);
        CurrentMode = query.TryGetValue("mode", out var m) ? m.ToString() : null;
    }

    #region Menu definitions
    private List<SidebarMenuItem> MerchantDashboard   => new() { new("Dashboard",       "/merchant/dashboard",                    "house") };
    private List<SidebarMenuItem> MerchantOperations  => new() { new("Orders",           "/merchant/orders",                       "file-stack"), new("Order Assignments", "/merchant/operations/assignments", "truck") };
    private List<SidebarMenuItem> MerchantUsers       => new() { new("Users",            "/merchant/users",                        "users"), new("Create User", "/merchant/createuser", "user-plus") };
    private List<SidebarMenuItem> MerchantStores      => new() { new("Create Store",     "/merchant/stores/create",                "create-store"), new("All Stores", "/merchant/stores", "warehouse"), new("Map", "/merchant/map", "map") };
    private List<SidebarMenuItem> MerchantProducts    => new()
    {
        new("Add Product",    "/merchant/products/create", "layers-plus"),
        new("Manage Product", ProductCtx.HasValue ? $"/merchant/products/{ProductCtx.ProductId}?mode=edit" : "/merchant/products?intent=manage", "wrench", active: IsManageProductActive),
        new("All Products",   "/merchant/products",        "layers")
    };
    private List<SidebarMenuItem> MerchantReports     => new() { new("Reports",  "/merchant/reports",  "chart-up"), new("Invoices", "/merchant/invoices", "") };
    private List<SidebarMenuItem> DriverDashboardItems  => new() { new("Overview",         "/driver/dashboard", "layout-panel-top") };
    private List<SidebarMenuItem> DriverDeliveriesItems => new() { new("My Tasks",         "/driver/deliveries","truck") };
    private List<SidebarMenuItem> DriverRouteItems      => new() { new("View Map",         "/driver/route",     "map") };
    private List<SidebarMenuItem> DriverProofItems      => new() { new("Confirm Delivery", "/driver/proof",     "package-check") };
    private List<SidebarMenuItem> CustomerDashboard     => new() { new("Dashboard",        "/customer/dashboard","dashboard") };
    private List<SidebarMenuItem> CustomerTrackOrder    => new() { new("Track Order",      "/customer/trackorder","map") };
    private List<SidebarMenuItem> CustomerOrders        => new() { new("My Orders",        "/customer/myorders", "package") };
    private List<SidebarMenuItem> CustomerFeedback      => new() { new("Rate Delivery",    "/customer/feedback", "thumbs-up") };
    private List<SidebarMenuItem> CustomerPayment       => new() { new("Payment",          "/customer/payment",  "credit-card") };
    private List<SidebarMenuItem> CustomerCheckout      => new() { new("Checkout",         "/customer/checkout", "cart") };
    #endregion
}
