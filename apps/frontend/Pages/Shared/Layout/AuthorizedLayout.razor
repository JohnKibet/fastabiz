@*
    AuthorizedLayout.razor
    ══════════════════════════════════════════════════════════════════

    WHY WE DO NOT USE <AuthorizeView> HERE
    ───────────────────────────────────────
    The standard Blazor pattern (<CascadingAuthenticationState> +
    <AuthorizeView>) causes a redirect loop because of a timing problem:

      1. GetAuthenticationStateAsync() must await a JS interop call to
         localStorage.getItem() to retrieve the JWT. This is async.

      2. While that await is in flight, AuthorizeView renders <NotAuthorized>
         immediately — it has no resolved state yet.

      3. Any NavigateTo() call inside <NotAuthorized> markup fires during
         the render pass, before auth is even known, causing the loop.

    OUR APPROACH
    ─────────────
    We call GetAuthenticationStateAsync() in OnInitializedAsync() which
    properly awaits the localStorage read before any rendering runs.
    Three explicit states drive the UI:

      • IsReady = false                         → spinner (auth not resolved)
      • IsReady = true, IsAuthenticated = false → render nothing; redirect
                                                  fires safely in OnAfterRender
      • IsReady = true, IsAuthenticated = true  → render full shell

    NavigateTo is called in OnAfterRender(firstRender:true) — not inside
    a render expression — because navigation during a render pass causes
    the redirect loop described above.

    CORRECT MudBlazor SHELL STRUCTURE
    ───────────────────────────────────
    MudDrawer (rendered by <Sidebar>) must be a direct child of MudLayout,
    NOT nested inside MudMainContent. MudLayout is a flex row; the drawer
    sits on the left and MudMainContent fills the remaining width.

        ┌─ MudLayout (flex row) ──────────────────────────────┐
        │  ┌─ MudDrawer (Sidebar) ─┐  ┌─ MudMainContent ───┐  │
        │  │  nav items            │  │  <Navbar />         │  │
        │  │                       │  │  <page content>     │  │
        │  └───────────────────────┘  └─────────────────────┘  │
        └────────────────────────────────────────────────────────┘

    ══════════════════════════════════════════════════════════════════
*@

@using frontend.Pages.Shared.Components
@using frontend.Services
@using System.Security.Claims
@using frontend.Pages.Shared.Sidebars
@using MudBlazor
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject CartService CartService
@implements IDisposable

@if (!IsReady)
{
    @* Waiting for localStorage JS interop to resolve auth.
       Never render content or redirect here — auth is not yet known. *@
    <div style="display:flex; align-items:center; justify-content:center; min-height:100vh; background:#f3f4f6;">
        <div class="d-flex flex-column align-center gap-4">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.body2" Style="color:#6b7280;">Loading…</MudText>
        </div>
    </div>
}
else if (!IsAuthenticated)
{
    @* Auth resolved — user is not logged in.
       Render nothing to avoid a content flash.
       The redirect fires in OnAfterRender once the render pass is complete. *@
}
else
{
    @* Auth confirmed — render the full shell *@
    <MudLayout Style="min-height:100vh; background:#f3f4f6; padding-bottom: 50px">

        @*
            Sidebar contains a MudDrawer and must sit as a direct child of
            MudLayout. Placing it inside MudMainContent would cause the drawer
            to overlap the content column instead of pushing it aside.
        *@
        <CascadingValue Value="UserRole">
            <CascadingValue Value="ActiveProductCtx">
                <Sidebar OnCollapseChanged="OnSidebarCollapseChanged" />
            </CascadingValue>
        </CascadingValue>

        @*
            MudMainContent fills the width not occupied by the drawer.
            padding-top:0 because our Navbar is sticky inside this column —
            it is NOT a fixed MudAppBar, so no top offset is needed here.
        *@
        <MudMainContent Style="display:flex; flex-direction:column; min-height:100vh; padding-top:0;">

            <CascadingValue Value="UserRole">
                <CascadingValue Value="UserId">
                    <Navbar UserName="@UserName" />
                </CascadingValue>
            </CascadingValue>

            <div style="flex:1; overflow-y:auto; padding:28px 32px; max-width:1400px; width:100%; margin:0 auto;">
                <CascadingValue Value="UserId">
                    @ChildContent
                </CascadingValue>
            </div>

        </MudMainContent>
    </MudLayout>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool RedirectToLogin { get; set; } = true;

    // Passed down from role-specific layouts (MerchantLayout, etc.)
    [CascadingParameter] public ActiveProductContext? ActiveProductCtx { get; set; }

    private bool IsReady;
    private bool IsAuthenticated;
    private bool IsSidebarCollapsed;
    private string? UserName;
    private string? UserRole;
    private Guid? UserId;

    private void OnSidebarCollapseChanged(bool collapsed) => IsSidebarCollapsed = collapsed;

    protected override async Task OnInitializedAsync()
    {
        CartService.OnChange += StateHasChanged;

        // Await the full auth resolution (includes the localStorage JS interop).
        // IsReady stays false — nothing renders — until this line completes.
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        IsAuthenticated = user.Identity?.IsAuthenticated == true;

        if (IsAuthenticated)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (Guid.TryParse(idClaim?.Value, out var guid))
                UserId = guid;

            var roleClaim = user.FindFirst(ClaimTypes.Role) ?? user.FindFirst("role");
            UserRole = roleClaim?.Value;

            var nameClaim = user.FindFirst(ClaimTypes.Name)
                         ?? user.FindFirst("name")
                         ?? user.FindFirst(ClaimTypes.Email)
                         ?? idClaim;

            var display = nameClaim?.Value?.Trim();
            if (!string.IsNullOrEmpty(display))
            {
                var first = display.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.Trim();
                UserName = !string.IsNullOrEmpty(first) ? first : "User";
            }
            else
            {
                UserName = "User";
            }
        }

        // Flip — Blazor re-renders automatically after OnInitializedAsync completes.
        IsReady = true;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        // Safe to navigate here — render pass is complete, IsReady is guaranteed true,
        // and IsAuthenticated reflects the real resolved state, not the loading transient.
        // forceLoad:false keeps the WASM runtime alive so _cachedUser in
        // CustomAuthStateProvider is not discarded by a hard reload.
        if (firstRender && IsReady && !IsAuthenticated && RedirectToLogin)
            Navigation.NavigateTo("/auth/login", forceLoad: false);
    }

    public void Dispose() => CartService.OnChange -= StateHasChanged;
}