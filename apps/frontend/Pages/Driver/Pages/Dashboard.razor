@page "/driver/dashboard"
@layout DriverLayout
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@attribute [Authorize(Roles = "driver")]

<!-- ── Page header ── -->
<div class="d-flex align-center justify-space-between mb-6 flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:800;">Driver Dashboard</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Here's your overview for today.</MudText>
    </div>
    <MudChip T="string" Icon="@Icons.Material.Filled.Circle" Color="Color.Success"
             Variant="MudVariant.Filled" Size="Size.Small" Label="true" Style="font-weight:600;">
        On Duty
    </MudChip>
</div>

<!-- ── New assignments banner ── -->
@if (_hasNewAssignments)
{
    <MudAlert Severity="Severity.Warning" Class="mb-6" Dense="false" NoIcon="false">
        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">
            @_newDeliveries.Count new deliver@(_newDeliveries.Count == 1 ? "y" : "ies") assigned
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1 mb-3">
            Accept them to add to today's route and update the map.
        </MudText>
        <div class="d-flex gap-3">
            <MudButton Variant="MudVariant.Filled" Color="Color.Success" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="AcceptDeliveries"
                       Style="border-radius:8px; font-weight:700;">
                Accept
            </MudButton>
            <MudButton Variant="MudVariant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Cancel"
                       OnClick="DeclineDeliveries"
                       Style="border-radius:8px; font-weight:700;">
                Decline
            </MudButton>
        </div>
    </MudAlert>
}

<!-- ── Metric cards ── -->
<MudGrid Spacing="4" Class="mb-6">
    <MudItem xs="12" sm="4">
        <MetricCard Title="Assigned"  Value="@_assignedCount.ToString()"
                    Icon="truck" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <MetricCard Title="Completed" Value="@_completedCount.ToString()"
                    Icon="box"    Highlight="success" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <MetricCard Title="Pending"   Value="@_pendingCount.ToString()"
                    Icon="clock"  Highlight="warning" />
    </MudItem>
</MudGrid>

<!-- ── Route map + delivery list ── -->
<MudGrid Spacing="4">

    <!-- Map -->
    <MudItem xs="12" lg="8">
        <DashboardPanel Title="Today's Route" Icon="@Icons.Material.Filled.Map">
            <div style="height:400px; width:100%; border-radius:10px; overflow:hidden;">
                <RealTimeMap @ref="_map" Parameters="_mapParams" height="400px" width="100%" />
            </div>
        </DashboardPanel>
    </MudItem>

    <!-- Stop list -->
    <MudItem xs="12" lg="4">
        <DashboardPanel Title="Stops" Icon="@Icons.Material.Filled.Pin">
            @if (!_deliveryStops.Any())
            {
                <div class="d-flex flex-column align-center py-6">
                    <MudIcon Icon="@Icons.Material.Filled.Route"
                             Style="font-size:2.5rem; color:#d1d5db;" Class="mb-2" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">No stops yet</MudText>
                </div>
            }
            else
            {
                <MudList T="string" Dense="true" Style="padding:0;">
                    @foreach (var (stop, i) in _deliveryStops.Select((s, i) => (s, i + 1)))
                    {
                        <MudListItem>
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Small"
                                           Style="@($"background:{StopColor(stop.Status)}; color:white; font-size:0.75rem; font-weight:700; width:28px; height:28px;")">
                                    @i
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@stop.Name</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@stop.Address</MudText>
                                </div>
                                <MudChip T="string" Size="Size.Small" Variant="MudVariant.Outlined"
                                         Color="@GetStopColor(stop.Status)" Label="true" Class="ml-auto">
                                    @stop.Status
                                </MudChip>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            }
        </DashboardPanel>
    </MudItem>
</MudGrid>

@code {
    private RealTimeMap? _map;
    private bool _hasNewAssignments = true;

    private List<DeliveryStop> _newDeliveries = new()
    {
        new("Stop 1", "Customer A", -1.2925, 36.8220, "Pending"),
        new("Stop 2", "Customer B", -1.2980, 36.8290, "Pending"),
    };

    private List<DeliveryStop> _deliveryStops = new();

    private int _assignedCount  => _deliveryStops.Count;
    private int _completedCount => _deliveryStops.Count(x => x.Status == "Completed");
    private int _pendingCount   => _deliveryStops.Count(x => x.Status == "Pending");

    private readonly RealTimeMap.LoadParameters _mapParams = new()
    {
        basemap = new RealTimeMap.Basemap
        {
            basemapLayers = new List<RealTimeMap.BasemapLayer>
            {
                new() {
                    url          = "http://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
                    attribution  = "©OpenStreetMap",
                    title        = "OpenStreetMap",
                    detectRetina = true
                }
            }
        },
        location = new RealTimeMap.Location { latitude = -1.29207, longitude = 36.82195 },
        zoomLevel = 13
    };

    private async Task AcceptDeliveries()
    {
        _deliveryStops.AddRange(_newDeliveries);
        _hasNewAssignments = false;
        StateHasChanged();

        if (_map is null) return;

        var points = new List<RealTimeMap.StreamPoint>
        {
            new() {
                guid      = Guid.NewGuid(),
                timestamp = DateTime.UtcNow,
                latitude  = -1.2921,
                longitude = 36.8219,
                type      = "driver",
                value     = "You"
            }
        };

        points.AddRange(_deliveryStops.Select(s => new RealTimeMap.StreamPoint
        {
            guid      = Guid.NewGuid(),
            timestamp = DateTime.UtcNow,
            latitude  = s.Lat,
            longitude = s.Lng,
            type      = "destination",
            value     = s.Name ?? string.Empty
        }));

        await _map.Geometric.Points.upload(points, true);
    }

    private void DeclineDeliveries()
    {
        _hasNewAssignments = false;
        _newDeliveries.Clear();
        // TODO: notify backend for reassignment
        StateHasChanged();
    }

    private static string StopColor(string? status) => status switch
    {
        "Completed" => "#16a34a",
        "Pending"   => "#d97706",
        _           => "#6b7280"
    };

    private static Color GetStopColor(string? status) => status switch
    {
        "Completed" => Color.Success,
        "Pending"   => Color.Warning,
        _           => Color.Default
    };

    private record DeliveryStop(string? Name, string? Address, double Lat, double Lng, string Status);
}
