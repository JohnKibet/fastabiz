@page "/driver/proof/{StopId:guid}"
@layout DriverLayout
@using frontend.Models
@using MudBlazor
@using MudVariant = MudBlazor.Variant
@inject DeliveryService DeliveryService
@inject ToastService ToastService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "driver")]

<MudText Typo="Typo.h5" Style="font-weight:800;" Class="mb-2">Proof of Delivery</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
    Stop ID: <span style="font-family:monospace;">@StopId.ToString()[..8]…</span>
</MudText>

<div style="max-width:480px;">

    <!-- Arrival status -->
    <MudAlert Severity="@(_hasArrived ? Severity.Success : Severity.Info)"
              Class="mb-6" Dense="true">
        @if (_hasArrived)
        {
            <span>📍 You are at the destination — ready to confirm.</span>
        }
        else
        {
            <span>Checking your location… confirm when you arrive.</span>
        }
    </MudAlert>

    <!-- OTP / code input -->
    <MudPaper Elevation="2" Class="pa-6 rounded-xl">
        <MudText Typo="Typo.subtitle2" Style="font-weight:700;" Class="mb-4">
            Enter the delivery code provided by the customer
        </MudText>

        <MudTextField @bind-Value="_code"
                      Label="Delivery Code / OTP"
                      Placeholder="e.g. 4829"
                      Variant="MudVariant.Outlined"
                      FullWidth="true"
                      Class="mb-2"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Pin"
                      InputType="InputType.Number"
                      For="@(() => _code)" />

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_error</MudAlert>
        }

        <MudButton Variant="MudVariant.Filled" Color="Color.Success"
                   FullWidth="true" Size="Size.Large"
                   OnClick="SubmitProof"
                   Disabled="@(_saving || string.IsNullOrWhiteSpace(_code))"
                   StartIcon="@Icons.Material.Filled.CheckCircle"
                   Style="border-radius:10px; font-weight:700;">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Confirming…</span>
            }
            else
            {
                <span>Complete Delivery</span>
            }
        </MudButton>
    </MudPaper>

    <!-- Navigation back -->
    <MudButton Variant="MudVariant.Text" Color="Color.Default" Class="mt-4"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Navigation.NavigateTo("/driver/deliveries"))">
        Back to Deliveries
    </MudButton>

</div>

@code {
    [Parameter] public Guid StopId { get; set; }

    private string? _code;
    private bool    _hasArrived = false;
    private bool    _saving     = false;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        // TODO: poll GPS and compare with stop coordinates
        // For now simulate a short check then mark arrived
        await Task.Delay(1200);
        _hasArrived = false; // flip to true when within radius
        StateHasChanged();
    }

    private async Task SubmitProof()
    {
        _error  = null;
        _saving = true;

        try
        {
            // TODO: replace with DeliveryService.ConfirmDelivery(StopId, _code)
            await Task.Delay(800); // simulate network call

            ToastService.ShowToast(
                "Delivery confirmed successfully!",
                string.Empty,
                ToastService.ToastLevel.Success);

            Navigation.NavigateTo("/driver/deliveries");
        }
        catch (Exception ex)
        {
            _error = $"Failed to confirm delivery: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
